<?xml version="1.0" encoding="UTF-8"?>
<!-- Original LuigiOS theme. No third-party product marks or system logos. -->
<theme defaultView="detailed">
  <formatVersion>7</formatVersion>
  <variables>
    <accent>22C55EFF</accent>
    <accentBright>66FF66FF</accentBright>
    <surface>000000FF</surface>
    <panel>121416F2</panel>
    <text>F5F7FAFF</text>
    <muted>A8B0BAFF</muted>
  </variables>
  <view name="screen">
    <text name="clock">
      <pos>0.835 0.025</pos><size>0.14 0.05</size><alignment>right</alignment>
      <verticalAlignment>center</verticalAlignment><fontSize>0.025</fontSize>
      <color>${text}</color>
    </text>
  </view>
  <view name="system">
    <image name="background" extra="static">
      <path>./art/background.png</path><pos>0 0</pos><size>1 1</size>
      <origin>0 0</origin><color>FFFFFFD8</color><zIndex>0</zIndex>
    </image>
    <image name="shade" extra="true">
      <path>./art/pixel.svg</path><pos>0 0</pos><size>1 1</size>
      <origin>0 0</origin><color>00000072</color><zIndex>2</zIndex>
    </image>
    <image name="brand" extra="static">
      <path>./art/logo.svg</path><pos>0.04 0.055</pos><maxSize>0.26 0.10</maxSize>
      <origin>0 0</origin><zIndex>20</zIndex>
    </image>
    <text name="brandName" extra="static">
      <text>LuigiOS</text><pos>0.105 0.060</pos><size>0.22 0.07</size>
      <verticalAlignment>center</verticalAlignment><fontSize>0.039</fontSize>
      <color>${text}</color><zIndex>21</zIndex>
    </text>
    <carousel name="systemcarousel">
      <pos>0 0.35</pos><size>1 0.30</size><color>000000D8</color>
      <colorEnd>121416F4</colorEnd><logoSize>0.21 0.12</logoSize>
      <logoScale>1.18</logoScale><maxLogoCount>5</maxLogoCount><zIndex>10</zIndex>
    </carousel>
    <text name="logoText">
      <fontSize>0.043</fontSize><color>${text}</color><forceUppercase>false</forceUppercase>
    </text>
    <text name="systemInfo">
      <pos>0.08 0.70</pos><size>0.84 0.12</size><alignment>center</alignment>
      <fontSize>0.026</fontSize><color>${muted}</color><zIndex>20</zIndex>
    </text>
    <text name="playerPromise" extra="true">
      <text>Games first. Your device. Your choices.</text><pos>0.08 0.88</pos>
      <size>0.84 0.05</size><alignment>center</alignment><fontSize>0.021</fontSize>
      <color>${accentBright}</color><zIndex>20</zIndex>
    </text>
  </view>
  <view name="basic, detailed, grid, gamecarousel">
    <image name="background">
      <path>./art/background.png</path><pos>0 0</pos><size>1 1</size>
      <origin>0 0</origin><color>FFFFFF78</color><zIndex>0</zIndex>
    </image>
    <image name="listShade" extra="true">
      <path>./art/pixel.svg</path><pos>0 0</pos><size>1 1</size>
      <origin>0 0</origin><color>000000C8</color><zIndex>1</zIndex>
    </image>
    <image name="brand" extra="static">
      <path>./art/logo.svg</path><pos>0.035 0.035</pos><maxSize>0.22 0.08</maxSize>
      <origin>0 0</origin><zIndex>20</zIndex>
    </image>
    <text name="brandName" extra="static">
      <text>LuigiOS</text><pos>0.095 0.039</pos><size>0.18 0.06</size>
      <verticalAlignment>center</verticalAlignment><fontSize>0.034</fontSize>
      <color>${text}</color><zIndex>21</zIndex>
    </text>
    <text name="logoText">
      <pos>0.29 0.035</pos><size>0.67 0.08</size><alignment>right</alignment>
      <fontSize>0.044</fontSize><color>${text}</color><zIndex>20</zIndex>
    </text>
    <image name="logo"><visible>false</visible></image>
    <textlist name="gamelist">
      <pos>0.035 0.16</pos><size>0.47 0.75</size><fontSize>0.029</fontSize>
      <primaryColor>${muted}</primaryColor><secondaryColor>${muted}</secondaryColor>
      <selectedColor>${text}</selectedColor><selectorColor>22C55E44</selectorColor>
      <scrollbarColor>22C55E88</scrollbarColor><horizontalMargin>0.012</horizontalMargin>
    </textlist>
  </view>
  <view name="detailed">
    <video name="md_video">
      <pos>0.745 0.35</pos><maxSize>0.44 0.38</maxSize><origin>0.5 0.5</origin>
      <delay>0.8</delay><showSnapshotNoVideo>true</showSnapshotNoVideo><zIndex>10</zIndex>
    </video>
    <text name="md_description">
      <pos>0.535 0.58</pos><size>0.425 0.25</size><fontSize>0.022</fontSize>
      <color>${muted}</color><zIndex>10</zIndex>
    </text>
    <text name="md_developer, md_genre, md_players">
      <pos>0.535 0.86</pos><size>0.425 0.04</size><fontSize>0.019</fontSize>
      <color>${text}</color><zIndex>10</zIndex>
    </text>
  </view>
  <view name="menu">
    <menuBackground name="menubg"><color>000000FA</color><cornerSize>8 8</cornerSize></menuBackground>
    <menuText name="menutitle"><fontSize>0.034</fontSize><color>${text}</color></menuText>
    <menuText name="menutext">
      <fontSize>0.027</fontSize><color>${muted}</color><selectedColor>${text}</selectedColor>
      <selectorColor>${accent}</selectorColor>
    </menuText>
    <menuTextSmall name="menutextsmall"><fontSize>0.018</fontSize><color>${accentBright}</color></menuTextSmall>
    <menuGroup name="menugroup"><fontSize>0.019</fontSize><color>${accentBright}</color></menuGroup>
  </view>
</theme>
