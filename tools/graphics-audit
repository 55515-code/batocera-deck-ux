#!/usr/bin/env python3
"""Inventory, review, and exactly replace LuigiOS graphics."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import pathlib
import re
import shutil
import struct
import sys
import tempfile
import xml.etree.ElementTree as ET


ROOT = pathlib.Path(__file__).resolve().parents[1]
DEFAULT_POLICY = ROOT / "branding/graphics-policy-v1.json"
DEFAULT_PROVENANCE = ROOT / "branding/PROVENANCE.json"
DEFAULT_REPLACEMENTS = ROOT / "branding/replacements-v1.json"
SPDX_PATTERN = re.compile(r"^(?:[A-Za-z0-9][A-Za-z0-9.+-]*|LicenseRef-[A-Za-z0-9.-]+)$")
REMOTE_REFERENCE = re.compile(r"^(?:https?:|file:|//|data:)", re.IGNORECASE)


def arguments(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--policy", type=pathlib.Path, default=DEFAULT_POLICY)
    parser.add_argument("--provenance", type=pathlib.Path, default=DEFAULT_PROVENANCE)
    parser.add_argument("--replacements", type=pathlib.Path, default=DEFAULT_REPLACEMENTS)
    commands = parser.add_subparsers(dest="command", required=True)

    commands.add_parser("validate-policy")
    source = commands.add_parser("verify-source")
    source.add_argument("--root", type=pathlib.Path, default=ROOT / "branding/assets")
    source.add_argument("--format", choices=("human", "json"), default="human")

    repository = commands.add_parser("verify-repository")
    repository.add_argument("--root", type=pathlib.Path, default=ROOT)
    repository.add_argument("--format", choices=("human", "json"), default="human")

    scan = commands.add_parser("scan")
    scan.add_argument("--root", type=pathlib.Path, required=True)
    scan.add_argument("--strict", action="store_true")
    scan.add_argument("--format", choices=("human", "json"), default="human")
    scan.add_argument("--output", type=pathlib.Path)

    image = commands.add_parser("scan-image")
    image.add_argument("--root", type=pathlib.Path, required=True)
    image.add_argument("--strict", action="store_true")
    image.add_argument("--format", choices=("human", "json"), default="human")
    image.add_argument("--output", type=pathlib.Path)

    replace = commands.add_parser("apply-replacements")
    replace.add_argument("--root", type=pathlib.Path, required=True)
    replace.add_argument("--apply", action="store_true")
    replace.add_argument("--format", choices=("human", "json"), default="human")
    return parser.parse_args(argv)


def load_json(path: pathlib.Path, label: str) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
        raise ValueError(f"cannot read {label} {path}: {error}") from error
    if not isinstance(value, dict):
        raise ValueError(f"{label} must be a JSON object")
    return value


def validate_contract(policy: dict, provenance: dict, replacements: dict) -> list[str]:
    errors: list[str] = []
    for label, value in (("policy", policy), ("provenance", provenance), ("replacements", replacements)):
        if value.get("schema_version") != 1:
            errors.append(f"{label}.schema_version must be 1")
    for key in ("asset_extensions", "classifications", "trademark_reviews",
                "release_approved_trademark_reviews", "required_provenance_fields",
                "reserved_terms", "exact_hash_denylist", "artifact_roots",
                "replacement_roots"):
        if not isinstance(policy.get(key), list):
            errors.append(f"policy.{key} must be a list")
    if not isinstance(provenance.get("assets"), dict):
        errors.append("provenance.assets must be an object")
    if not isinstance(replacements.get("replacements"), list):
        errors.append("replacements.replacements must be a list")
    roots = policy.get("artifact_roots", []) + policy.get("replacement_roots", [])
    if any(not isinstance(root, str) or not root.startswith("/") or ".." in pathlib.PurePosixPath(root).parts for root in roots):
        errors.append("every artifact root must be a safe absolute path")
    return errors


def sha256(path: pathlib.Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as stream:
        for block in iter(lambda: stream.read(1024 * 1024), b""):
            digest.update(block)
    return digest.hexdigest()


def dimensions(path: pathlib.Path) -> list[int] | None:
    try:
        header = path.read_bytes()[:32]
        if header[:8] == b"\x89PNG\r\n\x1a\n" and header[12:16] == b"IHDR":
            return list(struct.unpack(">II", header[16:24]))
        if header[:6] in (b"GIF87a", b"GIF89a"):
            return list(struct.unpack("<HH", header[6:10]))
        if header[:2] == b"BM" and len(header) >= 26:
            return [abs(struct.unpack("<i", header[18:22])[0]), abs(struct.unpack("<i", header[22:26])[0])]
        if path.suffix.lower() == ".svg":
            node = ET.parse(path).getroot()
            width = numeric_svg_dimension(node.get("width"))
            height = numeric_svg_dimension(node.get("height"))
            if width is not None and height is not None:
                return [width, height]
            view_box = node.get("viewBox", "").replace(",", " ").split()
            if len(view_box) == 4:
                return [int(float(view_box[2])), int(float(view_box[3]))]
    except (OSError, ValueError, struct.error, ET.ParseError):
        return None
    return None


def numeric_svg_dimension(value: str | None) -> int | None:
    if not value:
        return None
    match = re.fullmatch(r"\s*(\d+(?:\.\d+)?)\s*(?:px)?\s*", value)
    return int(float(match.group(1))) if match else None


def unsafe_svg_references(path: pathlib.Path) -> list[str]:
    if path.suffix.lower() != ".svg":
        return []
    try:
        tree = ET.parse(path)
    except (OSError, ET.ParseError):
        return ["invalid SVG"]
    found = []
    for node in tree.iter():
        for name, value in node.attrib.items():
            if name.endswith("href") and REMOTE_REFERENCE.match(value.strip()):
                found.append(value)
    return sorted(set(found))


def asset_paths(root: pathlib.Path, extensions: set[str]) -> tuple[list[pathlib.Path], list[str]]:
    files: list[pathlib.Path] = []
    errors: list[str] = []
    if not root.is_dir():
        return files, [f"scan root is not a directory: {root}"]
    for path in sorted(root.rglob("*"), key=lambda item: item.as_posix().lower()):
        if ".git" in path.relative_to(root).parts:
            continue
        if path.is_symlink() and path.suffix.lower() in extensions:
            errors.append(f"symlinked asset is not allowed: {path.relative_to(root).as_posix()}")
        elif path.is_file() and path.suffix.lower() in extensions:
            files.append(path)
    return files, errors


def provenance_key(path: pathlib.Path, scan_root: pathlib.Path) -> str:
    try:
        return path.relative_to(ROOT / "branding").as_posix()
    except ValueError:
        return path.relative_to(scan_root).as_posix()


def inspect_assets(
    root: pathlib.Path,
    policy: dict,
    provenance: dict,
    strict: bool,
    key_prefix: str | None = None,
) -> dict:
    extensions = {str(value).lower() for value in policy.get("asset_extensions", [])}
    paths, errors = asset_paths(root, extensions)
    warnings: list[str] = []
    inventory = []
    assets = provenance.get("assets", {})
    denied = {
        item if isinstance(item, str) else item.get("sha256")
        for item in policy.get("exact_hash_denylist", [])
        if isinstance(item, (str, dict))
    }
    reserved = [str(term).lower() for term in policy.get("reserved_terms", [])]
    approved = set(policy.get("release_approved_trademark_reviews", []))
    required = policy.get("required_provenance_fields", [])

    for path in paths:
        relative = path.relative_to(root).as_posix()
        key = (
            key_prefix.rstrip("/") + "/" + relative
            if key_prefix is not None
            else provenance_key(path, root)
        )
        digest = sha256(path)
        raw = path.read_bytes()
        text = relative.lower()
        if path.suffix.lower() == ".svg":
            text += " " + raw.decode("utf-8", errors="ignore").lower()
        terms = sorted(term for term in reserved if term in text)
        external = unsafe_svg_references(path)
        record = assets.get(key)
        item = {
            "path": relative,
            "provenance_key": key,
            "sha256": digest,
            "bytes": len(raw),
            "dimensions": dimensions(path),
            "metadata_present": any(marker in raw for marker in (b"Exif\x00", b"<x:xmpmeta", b"XML:com.adobe.xmp")),
            "reserved_terms": terms,
            "unsafe_svg_references": external,
            "provenance": record,
        }
        inventory.append(item)
        if len(raw) == 0:
            errors.append(f"{relative}: empty asset")
        if digest in denied:
            errors.append(f"{relative}: exact hash is denied by policy")
        if external:
            errors.append(f"{relative}: SVG contains external or embedded references")
        if record is None:
            message = f"{relative}: missing provenance entry {key}"
            (errors if strict else warnings).append(message)
            continue
        if not isinstance(record, dict):
            errors.append(f"{relative}: provenance entry must be an object")
            continue
        missing = [field for field in required if field not in record]
        if missing:
            errors.append(f"{relative}: provenance missing {', '.join(missing)}")
        if record.get("sha256") != digest:
            errors.append(f"{relative}: provenance hash does not match asset")
        if record.get("classification") not in policy.get("classifications", []):
            errors.append(f"{relative}: invalid provenance classification")
        review = record.get("trademark_review")
        if review not in policy.get("trademark_reviews", []):
            errors.append(f"{relative}: invalid trademark_review")
        if strict and review not in approved:
            errors.append(f"{relative}: trademark review is not release-approved ({review})")
        license_id = record.get("spdx_license")
        if not isinstance(license_id, str) or not SPDX_PATTERN.fullmatch(license_id):
            errors.append(f"{relative}: spdx_license must be an SPDX id or LicenseRef")
        if terms and review not in {"approved-nominative", "licensed"}:
            errors.append(f"{relative}: reserved terms require explicit trademark review: {', '.join(terms)}")

    return {
        "schema_version": 1,
        "root": str(root.resolve()),
        "strict": strict,
        "assets": inventory,
        "errors": sorted(set(errors)),
        "warnings": sorted(set(warnings)),
        "valid": not errors,
    }


def inspect_image(root: pathlib.Path, policy: dict, provenance: dict, strict: bool) -> dict:
    reports = []
    errors: list[str] = []
    warnings: list[str] = []
    inventory = []
    for configured in policy.get("artifact_roots", []):
        scan_root = root / configured.lstrip("/")
        if not scan_root.exists():
            warnings.append(f"configured graphics root is absent: {configured}")
            continue
        report = inspect_assets(scan_root, policy, provenance, strict, configured)
        for asset in report["assets"]:
            asset = dict(asset)
            asset["path"] = configured.rstrip("/") + "/" + asset["path"]
            inventory.append(asset)
        errors.extend(f"{configured}: {message}" for message in report["errors"])
        warnings.extend(f"{configured}: {message}" for message in report["warnings"])
        reports.append({"root": configured, "assets": len(report["assets"])})
    if not root.is_dir():
        errors.append(f"image root is not a directory: {root}")
    return {
        "schema_version": 1,
        "root": str(root.resolve()),
        "strict": strict,
        "scanned_roots": reports,
        "assets": sorted(inventory, key=lambda item: item["path"]),
        "errors": sorted(set(errors)),
        "warnings": sorted(set(warnings)),
        "valid": not errors,
    }


def safe_relative(value: object) -> pathlib.PurePosixPath | None:
    if not isinstance(value, str) or not value:
        return None
    path = pathlib.PurePosixPath(value)
    if path.is_absolute() or ".." in path.parts:
        return None
    return path


def has_symlink_component(path: pathlib.Path, stop: pathlib.Path) -> bool:
    current = path
    while current != stop:
        if current.is_symlink():
            return True
        if current.parent == current:
            return True
        current = current.parent
    return stop.is_symlink()


def provenance_errors(record: object, policy: dict, digest: str) -> list[str]:
    if not isinstance(record, dict):
        return ["provenance entry is missing or not an object"]
    errors = []
    missing = [field for field in policy.get("required_provenance_fields", []) if field not in record]
    if missing:
        errors.append(f"provenance missing {', '.join(missing)}")
    if record.get("sha256") != digest:
        errors.append("provenance hash does not match asset")
    if record.get("classification") not in policy.get("classifications", []):
        errors.append("invalid provenance classification")
    if record.get("trademark_review") not in policy.get("release_approved_trademark_reviews", []):
        errors.append("provenance trademark review is not release-approved")
    license_id = record.get("spdx_license")
    if not isinstance(license_id, str) or not SPDX_PATTERN.fullmatch(license_id):
        errors.append("provenance license is not an SPDX id or LicenseRef")
    return errors


def replacement_plan(root: pathlib.Path, policy: dict, provenance: dict, manifest: dict, apply: bool) -> dict:
    errors: list[str] = []
    operations = []
    allowed_roots = tuple(policy.get("replacement_roots", []))
    provenance_assets = provenance.get("assets", {})
    seen_ids: set[str] = set()
    seen_destinations: set[str] = set()
    for position, entry in enumerate(manifest.get("replacements", [])):
        label = entry.get("id", f"replacement {position}") if isinstance(entry, dict) else f"replacement {position}"
        if not isinstance(entry, dict):
            errors.append(f"{label}: must be an object")
            continue
        if not isinstance(label, str) or not label or label in seen_ids:
            errors.append(f"replacement {position}: id must be a unique non-empty string")
            continue
        seen_ids.add(label)
        destination = entry.get("destination")
        source_rel = safe_relative(entry.get("source"))
        expected = entry.get("expected_sha256")
        source_expected = entry.get("source_sha256")
        if not isinstance(destination, str) or not destination.startswith("/") or ".." in pathlib.PurePosixPath(destination).parts:
            errors.append(f"{label}: destination must be a safe absolute path")
            continue
        if not any(destination == base or destination.startswith(base + "/") for base in allowed_roots):
            errors.append(f"{label}: destination is outside audited artifact roots")
            continue
        if destination in seen_destinations:
            errors.append(f"{label}: duplicate replacement destination")
            continue
        seen_destinations.add(destination)
        if source_rel is None:
            errors.append(f"{label}: source must be relative to branding")
            continue
        source = ROOT / "branding" / pathlib.Path(*source_rel.parts)
        target = root / destination.lstrip("/")
        if not source.is_file() or has_symlink_component(source, ROOT / "branding"):
            errors.append(f"{label}: replacement source is missing or unsafe")
            continue
        actual_source = sha256(source)
        record = provenance_assets.get(source_rel.as_posix())
        source_provenance_errors = provenance_errors(record, policy, actual_source)
        if source_provenance_errors:
            errors.extend(f"{label}: {message}" for message in source_provenance_errors)
            continue
        if not target.is_file() or has_symlink_component(target, root):
            errors.append(f"{label}: destination is missing or unsafe")
            continue
        actual_target = sha256(target)
        if not isinstance(source_expected, str) or actual_source != source_expected:
            errors.append(f"{label}: replacement source hash mismatch")
            continue
        if not isinstance(expected, str) or actual_target != expected:
            errors.append(f"{label}: upstream destination hash mismatch")
            continue
        operations.append({"id": label, "source": str(source), "destination": destination,
                           "old_sha256": actual_target, "new_sha256": actual_source})

    if apply and not errors:
        for operation in operations:
            target = root / operation["destination"].lstrip("/")
            target.parent.mkdir(parents=True, exist_ok=True)
            descriptor, temporary = tempfile.mkstemp(prefix=f".{target.name}.", dir=target.parent)
            os.close(descriptor)
            try:
                shutil.copyfile(operation["source"], temporary)
                os.replace(temporary, target)
            finally:
                pathlib.Path(temporary).unlink(missing_ok=True)
    return {"applied": apply and not errors, "operations": operations,
            "errors": sorted(set(errors)), "valid": not errors}


def emit(report: dict, style: str, output: pathlib.Path | None = None) -> None:
    rendered = json.dumps(report, indent=2, sort_keys=True) + "\n"
    if output:
        output.parent.mkdir(parents=True, exist_ok=True)
        output.write_text(rendered, encoding="utf-8")
    if style == "json":
        print(rendered, end="")
        return
    for error in report.get("errors", []):
        print(f"ERROR: {error}")
    for warning in report.get("warnings", []):
        print(f"WARNING: {warning}")
    count = len(report.get("assets", report.get("operations", [])))
    print(f"graphics audit: {'PASS' if report.get('valid') else 'FAIL'} ({count} item(s))")


def main(argv: list[str]) -> int:
    args = arguments(argv)
    try:
        policy = load_json(args.policy, "graphics policy")
        provenance = load_json(args.provenance, "provenance manifest")
        replacements = load_json(args.replacements, "replacement manifest")
    except ValueError as error:
        print(error, file=sys.stderr)
        return 1
    contract_errors = validate_contract(policy, provenance, replacements)
    if args.command == "validate-policy":
        report = {"valid": not contract_errors, "errors": contract_errors}
        emit(report, "human")
        return 0 if report["valid"] else 1
    if contract_errors:
        emit({"valid": False, "errors": contract_errors}, "human")
        return 1
    if args.command == "verify-source":
        report = inspect_assets(args.root, policy, provenance, strict=True)
        emit(report, args.format)
    elif args.command == "verify-repository":
        report = inspect_assets(args.root, policy, provenance, strict=True)
        emit(report, args.format)
    elif args.command == "scan":
        report = inspect_assets(args.root, policy, provenance, strict=args.strict)
        emit(report, args.format, args.output)
    elif args.command == "scan-image":
        report = inspect_image(args.root, policy, provenance, strict=args.strict)
        emit(report, args.format, args.output)
    else:
        report = replacement_plan(args.root, policy, provenance, replacements, args.apply)
        emit(report, args.format)
    return 0 if report["valid"] else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
