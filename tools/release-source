#!/usr/bin/env python3
import argparse
import gzip
import hashlib
import json
import subprocess
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]


def git(*args):
    return subprocess.run(
        ["git", *args],
        cwd=ROOT,
        check=True,
        capture_output=True,
    ).stdout


def build_release(output_dir, revision="HEAD", require_clean=True):
    if require_clean and git("status", "--porcelain").strip():
        raise RuntimeError("release source must be built from a clean worktree")

    version = (ROOT / "VERSION").read_text(encoding="utf-8").strip()
    commit = git("rev-parse", revision).decode().strip()
    name = f"batocera-deck-ux-{version}"
    output_dir.mkdir(parents=True, exist_ok=True)
    archive = output_dir / f"{name}.tar.gz"

    tar_bytes = git("archive", "--format=tar", f"--prefix={name}/", commit)
    with archive.open("wb") as raw:
        with gzip.GzipFile(fileobj=raw, mode="wb", filename="", mtime=0) as compressed:
            compressed.write(tar_bytes)

    digest = hashlib.sha256(archive.read_bytes()).hexdigest()
    checksum = output_dir / f"{archive.name}.sha256"
    checksum.write_text(f"{digest}  {archive.name}\n", encoding="ascii")
    manifest = output_dir / f"{name}.source.json"
    manifest.write_text(
        json.dumps(
            {
                "schema_version": 1,
                "version": version,
                "commit": commit,
                "archive": archive.name,
                "sha256": digest,
                "artifact_kind": "contributor-source",
                "end_user_os_image": False,
            },
            indent=2,
            sort_keys=True,
        )
        + "\n",
        encoding="utf-8",
    )
    return archive, checksum, manifest


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--output", type=Path, default=ROOT / "dist")
    parser.add_argument("--revision", default="HEAD")
    args = parser.parse_args()
    for path in build_release(args.output, args.revision):
        print(path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
