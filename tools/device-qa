#!/usr/bin/env python3
"""Run non-mutating LuigiOS qualification probes over SSH."""

from __future__ import annotations

import argparse
from datetime import datetime, timezone
import json
from pathlib import Path
import subprocess
import sys


ROOT = Path(__file__).resolve().parents[1]
DEFAULT_POLICY = ROOT / "profiles/beta-qualification-v1.json"

REMOTE_PROBE = r"""
set -eu
value() { printf '%s=%s\n' "$1" "$2"; }
mount_value() { findmnt -rn -o "$2" --target "$1" 2>/dev/null | head -n 1 || true; }
df_value() { df -Pk "$1" 2>/dev/null | awk 'NR == 2 { print $'"$2"' }'; }

value QA_SCHEMA 1
value HOSTNAME "$(hostname 2>/dev/null || true)"
value BATOCERA_VERSION "$(batocera-version 2>/dev/null || true)"
value KERNEL "$(uname -r 2>/dev/null || true)"
value USERDATA_SOURCE "$(mount_value /userdata SOURCE)"
value USERDATA_FSTYPE "$(mount_value /userdata FSTYPE)"
value USERDATA_OPTIONS "$(mount_value /userdata OPTIONS)"
value USERDATA_TOTAL_KIB "$(df_value /userdata 2)"
value USERDATA_AVAILABLE_KIB "$(df_value /userdata 4)"
value ROM_SOURCE "$(mount_value /userdata/roms SOURCE)"
value ROM_FSTYPE "$(mount_value /userdata/roms FSTYPE)"
value ROM_OPTIONS "$(mount_value /userdata/roms OPTIONS)"
value ROM_TOTAL_KIB "$(df_value /userdata/roms 2)"
value ROM_AVAILABLE_KIB "$(df_value /userdata/roms 4)"
value USERDATA_DEVICE_ID "$(stat -c %d /userdata/system 2>/dev/null || true)"
value ROM_DEVICE_ID "$(stat -c %d /userdata/roms 2>/dev/null || true)"
value SSH_DAEMON_COUNT "$(pgrep -c dropbear 2>/dev/null || pgrep -c sshd 2>/dev/null || printf 0)"
value PRODUCT_DESKTOP_MARKER "$(test -e /userdata/system/configs/batocera-deck-desktop.enabled && printf present || printf absent)"
value LEGACY_DESKTOP_MARKER "$(test -e /userdata/system/configs/arch-plasma.enabled && printf present || printf absent)"
value BRAND_IDENTITY "$(test -f /userdata/system/configs/luigios/identity.json && printf present || printf absent)"
value BRAND_MANIFEST "$(test -f /userdata/system/configs/luigios/brand-v1.json && printf present || printf absent)"
value SETTINGS_APP "$(test -x /usr/bin/luigios-settings && printf present || printf absent)"
value MIGRATION_TOOL "$(test -x /usr/bin/deck-migrate && printf present || printf absent)"
value BACKUP_UI "$(test -x /usr/bin/luigios-backup && printf present || printf absent)"
value COSMIC_ROOTFS "$(test -d /userdata/system/containers/arch-cosmic/rootfs && printf present || printf absent)"
value PLASMA_ROOTFS "$(test -d /userdata/system/containers/arch-plasma/rootfs && printf present || printf absent)"
value DEV_CONNECTIVITY_GUARD "$(test -x /usr/libexec/luigios/dev-connectivity-guard && printf present || printf absent)"
value DEV_CONNECTIVITY_SERVICE "$(test -x /etc/init.d/S07luigios-dev-connectivity && printf present || printf absent)"
"""


def parse_probe(stdout: str) -> dict[str, str]:
    values = {}
    for line in stdout.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key] = value
    if values.get("QA_SCHEMA") != "1":
        raise ValueError("remote probe did not return the expected schema")
    return values


def integer(values: dict[str, str], key: str) -> int:
    try:
        return int(values.get(key, ""))
    except ValueError:
        return 0


def check(identifier: str, passed: bool, evidence: str, blocking: bool = True) -> dict:
    return {
        "id": identifier,
        "status": "pass" if passed else "fail",
        "blocking": blocking,
        "evidence": evidence,
    }


def evaluate(values: dict[str, str], policy: dict) -> list[dict]:
    qa = policy["device_qa"]
    available = integer(values, "USERDATA_AVAILABLE_KIB")
    total = integer(values, "USERDATA_TOTAL_KIB")
    free_percent = (available * 100 // total) if total else 0
    rom_source = values.get("ROM_SOURCE", "")
    userdata_source = values.get("USERDATA_SOURCE", "")
    return [
        check("luigios-hostname", values.get("HOSTNAME") == "LUIGIOS", values.get("HOSTNAME", "missing")),
        check("userdata-mounted", bool(userdata_source), userdata_source or "missing"),
        check("userdata-writeable", "rw" in values.get("USERDATA_OPTIONS", "").split(","), values.get("USERDATA_OPTIONS", "missing")),
        check(
            "userdata-capacity",
            available >= qa["minimum_userdata_free_kib"] and free_percent >= qa["minimum_userdata_free_percent"],
            f"{available} KiB available ({free_percent}%)",
        ),
        check("rom-mount-present", bool(rom_source), rom_source or "missing"),
        check("rom-mount-removable", rom_source.startswith(qa["expected_removable_source_prefix"]), rom_source or "missing"),
        check(
            "rom-storage-separated",
            bool(values.get("ROM_DEVICE_ID")) and values.get("ROM_DEVICE_ID") != values.get("USERDATA_DEVICE_ID"),
            f"userdata={values.get('USERDATA_DEVICE_ID', 'missing')} rom={values.get('ROM_DEVICE_ID', 'missing')}",
        ),
        check("ssh-daemon-active", integer(values, "SSH_DAEMON_COUNT") > 0, values.get("SSH_DAEMON_COUNT", "0")),
        check("brand-identity-deployed", values.get("BRAND_IDENTITY") == "present", values.get("BRAND_IDENTITY", "missing"), False),
        check("brand-manifest-deployed", values.get("BRAND_MANIFEST") == "present", values.get("BRAND_MANIFEST", "missing"), False),
        check("source-desktop-enabled", values.get("PRODUCT_DESKTOP_MARKER") == "present", values.get("PRODUCT_DESKTOP_MARKER", "missing"), False),
        check("cosmic-rootfs-provisioned", values.get("COSMIC_ROOTFS") == "present", values.get("COSMIC_ROOTFS", "missing"), False),
        check("settings-app-installed", values.get("SETTINGS_APP") == "present", values.get("SETTINGS_APP", "missing"), False),
        check("migration-tool-installed", values.get("MIGRATION_TOOL") == "present", values.get("MIGRATION_TOOL", "missing"), False),
        check("backup-ui-installed", values.get("BACKUP_UI") == "present", values.get("BACKUP_UI", "missing"), False),
        check("developer-connectivity-guard-installed", values.get("DEV_CONNECTIVITY_GUARD") == "present", values.get("DEV_CONNECTIVITY_GUARD", "missing"), False),
        check("developer-connectivity-service-installed", values.get("DEV_CONNECTIVITY_SERVICE") == "present", values.get("DEV_CONNECTIVITY_SERVICE", "missing"), False),
    ]


def parser() -> argparse.ArgumentParser:
    result = argparse.ArgumentParser(prog="device-qa")
    result.add_argument("--host", default="root@batocera.local")
    result.add_argument("--identity-file", type=Path)
    result.add_argument("--policy", type=Path, default=DEFAULT_POLICY)
    result.add_argument("--output", type=Path)
    result.add_argument("--require-beta", action="store_true")
    return result


def main() -> int:
    args = parser().parse_args()
    policy = json.loads(args.policy.read_text(encoding="utf-8"))
    command = [
        "ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8",
        "-o", "ConnectionAttempts=1", "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=2", "-o", "StrictHostKeyChecking=yes",
    ]
    if args.identity_file:
        command.extend(["-i", str(args.identity_file), "-o", "IdentitiesOnly=yes"])
    command.extend([args.host, "sh -s"])
    completed = subprocess.run(command, input=REMOTE_PROBE, text=True, capture_output=True)
    if completed.returncode:
        print(completed.stderr.strip() or "SSH probe failed", file=sys.stderr)
        return 2
    values = parse_probe(completed.stdout)
    checks = evaluate(values, policy)
    blockers = [item["id"] for item in checks if item["blocking"] and item["status"] != "pass"]
    beta_missing = [item["id"] for item in checks if item["status"] != "pass"]
    report = {
        "schema_version": 1,
        "generated_at_utc": datetime.now(timezone.utc).isoformat(),
        "mode": "read-only",
        "host": args.host,
        "facts": values,
        "checks": checks,
        "preflight_passed": not blockers,
        "beta_ready": not beta_missing,
        "blockers": blockers,
        "beta_missing": beta_missing,
    }
    rendered = json.dumps(report, indent=2) + "\n"
    if args.output:
        args.output.parent.mkdir(parents=True, exist_ok=True)
        args.output.write_text(rendered, encoding="utf-8")
    print(rendered, end="")
    if blockers or (args.require_beta and beta_missing):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
