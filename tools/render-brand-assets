def digest(path: pathlib.Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def write(path: pathlib.Path, data: bytes) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_bytes(data)


def run_magick(source: pathlib.Path, output: pathlib.Path, *operations: str) -> None:
    command = shutil.which("magick")
    if command is None:
        raise SystemExit("ImageMagick 'magick' is required to render raster assets")
    output.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run(
        [command, "-background", "none", str(source), *operations, str(output)],
        check=True,
        env=RENDER_ENV,
    )


def render_community_assets(destination: pathlib.Path) -> None:
    command = shutil.which("magick")
    if command is None:
        raise SystemExit("ImageMagick 'magick' is required to render raster assets")
    avatar = destination / "community/avatar-512.png"
    avatar.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run(
        [command, "-background", "none", str(destination / "core/luigios-symbolic.svg"),
         "-resize", "288x288", "-background", SURFACE, "-gravity", "center",
         "-extent", "512x512", "-strip", str(avatar)],
        check=True,
        env=RENDER_ENV,
    )
    banner = destination / "community/banner-1920x480.png"
    subprocess.run(
        [command, str(destination / "desktop/wallpapers/luigios/1920x1080.png"),
         "-gravity", "center", "-crop", "1920x480+0+0", "+repage",
         "(", "-background", "none", str(destination / "core/luigios-symbolic.svg"),
         "-resize", "144x144", ")", "-gravity", "west", "-geometry", "+96+0",
         "-composite", "-strip", str(banner)],
        check=True,
        env=RENDER_ENV,
    )


def copy_generated(source: pathlib.Path, destination: pathlib.Path) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, destination)


def write_local_provenance(directory: pathlib.Path, files: list[pathlib.Path]) -> None:
    payload = {
        "schema_version": 1,
        "generator": "tools/render-brand-assets",
        "license": "CC-BY-SA-4.0",
        "files": {
            path.relative_to(directory).as_posix(): hashlib.sha256(path.read_bytes()).hexdigest()
            for path in sorted(files)
        },
    }
    write(directory / "PROVENANCE.json", (json.dumps(payload, indent=2) + "\n").encode())


def render_product_surfaces(destination: pathlib.Path) -> None:
    theme = destination / "game-mode/theme"
    write(theme / "theme.xml", THEME_XML.encode())
    write(theme / "art/pixel.svg", PIXEL_SVG.encode())
    copy_generated(destination / "desktop/wallpapers/luigios/1280x800.png", theme / "art/background.png")
    copy_generated(destination / "core/luigios-logo.svg", theme / "art/logo.svg")
    write_local_provenance(theme, [theme / "theme.xml", theme / "art/pixel.svg", theme / "art/background.png", theme / "art/logo.svg"])

    settings = destination / "system/settings-icons"
    settings_files = []
    for name in SETTINGS_ICONS:
        target = settings / f"{name}.svg"
        copy_generated(destination / f"semantic/{name}.svg", target)
        settings_files.append(target)
    write_local_provenance(settings, settings_files)

    recovery = destination / "system/recovery"
    recovery_files = []
    for source, name in (
        (destination / "semantic/recovery.svg", "recovery.svg"),
        (ASSETS / "mascot/caretaker-angel.png", "caretaker-angel.png"),
        (ASSETS / "mascot/caretaker-demon.png", "caretaker-demon.png"),
    ):
        target = recovery / name
        copy_generated(source, target)
        recovery_files.append(target)
    write_local_provenance(recovery, recovery_files)

    command = shutil.which("ffmpeg")
    if command is None:
        raise SystemExit("ffmpeg is required to render the boot splash")
    frame = destination / "boot/luigios-splash-frame.png"
    copy_generated(destination / "desktop/wallpapers/luigios/1280x800.png", frame)
    splash = destination / "boot/luigios-splash.mp4"
    subprocess.run(
        [command, "-loglevel", "error", "-y", "-filter_threads", "1",
         "-filter_complex_threads", "1", "-loop", "1", "-framerate", "30",
         "-i", str(frame), "-t", "3", "-vf",
         "fade=t=in:st=0:d=0.35,fade=t=out:st=2.55:d=0.45,format=yuv420p",
         "-an", "-c:v", "mpeg4", "-q:v", "2", "-threads", "1",
         "-movflags", "+faststart", "-map_metadata", "-1", "-fflags", "+bitexact",
         "-flags:v", "+bitexact", str(splash)],
        check=True,
        env=RENDER_ENV,
    )


def render(destination: pathlib.Path) -> None:
    if not MASTER.is_file() or digest(MASTER) != MASTER_SHA256:
        raise SystemExit("wallpaper master is missing or does not match its reviewed hash")
    write(destination / "core/luigios-symbolic.svg", SYMBOL.encode())
    write(destination / "core/luigios-logo.svg", LOGO.encode())
    for name, data in ICONS.items():
        write(destination / f"semantic/{name}.svg", data.encode())

    run_magick(MASTER, destination / "desktop/wallpapers/luigios/1280x800.png",
               "-resize", "1280x800!", "-level", "8%,100%", "-strip")
    run_magick(MASTER, destination / "desktop/wallpapers/luigios/1920x1080.png",
               "-gravity", "south", "-crop", "1586x892+0+0", "+repage",
               "-resize", "1920x1080!", "-level", "8%,100%", "-strip")
    for geometry, filename in (("1280x800", "boot-logo-1280x800.png"),
                               ("1024x768", "boot-logo-4x3.png")):
        run_magick(destination / "core/luigios-symbolic.svg", destination / f"boot/{filename}",
                   "-resize", "192x192", "-background", SURFACE, "-gravity", "center",
                   "-extent", geometry,
                   "-strip")
    render_community_assets(destination)
    render_product_surfaces(destination)


def compare(rendered: pathlib.Path) -> list[str]:
    differences = []
    expected = {path.relative_to(rendered) for path in rendered.rglob("*") if path.is_file()}
    existing = {path.relative_to(ASSETS) for path in ASSETS.rglob("*") if path.is_file()}
    managed = {path for path in existing if path.parts[0] in {"boot", "community", "core", "game-mode", "semantic", "system"}}
    managed.update(path for path in existing if path.parts[:3] == ("desktop", "wallpapers", "luigios"))
    for relative in sorted(expected | managed):
        generated = rendered / relative
        current = ASSETS / relative
        if not generated.is_file() or not current.is_file() or generated.read_bytes() != current.read_bytes():
            differences.append(relative.as_posix())
    return differences


def update_global_provenance(rendered: pathlib.Path) -> None:
    provenance_path = BRANDING / "PROVENANCE.json"
    provenance = json.loads(provenance_path.read_text(encoding="utf-8"))
    records = provenance.get("assets", {})
    missing = []
    for path in rendered.rglob("*"):
        if not path.is_file() or path.suffix.lower() not in {".mp4", ".png", ".svg"}:
            continue
        key = f"assets/{path.relative_to(rendered).as_posix()}"
        record = records.get(key)
        if not isinstance(record, dict):
            missing.append(key)
            continue
        record["sha256"] = digest(path)
    if missing:
        raise SystemExit("missing global provenance for: " + ", ".join(sorted(missing)))
    write(provenance_path, (json.dumps(provenance, indent=2) + "\n").encode())


def adopt(rendered: pathlib.Path) -> int:
    if not rendered.is_dir():
        raise SystemExit(f"render output does not exist: {rendered}")
    files = [path for path in rendered.rglob("*") if path.is_file()]
    if not files:
        raise SystemExit("render output is empty")
    for path in files:
        target = ASSETS / path.relative_to(rendered)
        write(target, path.read_bytes())
    update_global_provenance(rendered)
    return len(files)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    modes = parser.add_mutually_exclusive_group()
    modes.add_argument("--check", action="store_true")
    modes.add_argument("--output", type=pathlib.Path)
    modes.add_argument("--adopt-output", type=pathlib.Path)
    args = parser.parse_args()
    if args.adopt_output:
        count = adopt(args.adopt_output)
        print(f"adopted {count} assets from pinned renderer")
        return 0
    if args.output:
        args.output.mkdir(parents=True, exist_ok=True)
        render(args.output)
        print(f"rendered {sum(1 for path in args.output.rglob('*') if path.is_file())} assets")
        return 0
    with tempfile.TemporaryDirectory() as temporary:
        rendered = pathlib.Path(temporary)
        render(rendered)
        differences = compare(rendered)
        if args.check:
            for path in differences:
                print(f"out of date: {path}")
            return int(bool(differences))
        print(f"rendered {adopt(rendered)} assets")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
