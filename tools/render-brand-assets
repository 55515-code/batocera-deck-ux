def svg(body: str, view_box: str = "0 0 24 24", width: int = 24, height: int = 24) -> str:
    return (
        f'<svg xmlns="http://www.w3.org/2000/svg" viewBox="{view_box}" '
        f'width="{width}" height="{height}" fill="none">\n'
        f"{body}\n</svg>\n"
    )


def icon(body: str, title: str) -> str:
    return svg(
        f"  <title>{title}</title>\n"
        f'  <g stroke="{GREEN}" stroke-width="2" stroke-linecap="round" '
        f'stroke-linejoin="round">\n{body}\n  </g>'
    )


