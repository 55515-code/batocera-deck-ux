#!/usr/bin/env bash
set -euo pipefail

ROOT=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
# shellcheck source=../sdk/versions.env
source "$ROOT/sdk/versions.env"

if [[ -n ${CONTAINER_RUNTIME:-} ]]; then
    runtime=$CONTAINER_RUNTIME
elif command -v docker >/dev/null 2>&1; then
    runtime=docker
else
    runtime=podman
fi

usage() {
    printf 'Usage: %s {plan|check|render}\n' "$0"
}

validate() {
    [[ $COSMIC_ARCH_IMAGE == *@sha256:* ]] || {
        echo "renderer image must use an immutable sha256 digest" >&2
        exit 1
    }
    [[ $COSMIC_ARCH_SNAPSHOT =~ ^20[0-9]{2}/(0[1-9]|1[0-2])/(0[1-9]|[12][0-9]|3[01])$ ]] || {
        echo "renderer snapshot must be YYYY/MM/DD" >&2
        exit 1
    }
}

plan() {
    python3 - "$COSMIC_ARCH_IMAGE" "$COSMIC_ARCH_SNAPSHOT" <<'PY'
import json, sys
print(json.dumps({
    "schema_version": 1,
    "image": sys.argv[1],
    "snapshot": sys.argv[2],
    "packages": ["ffmpeg", "imagemagick", "librsvg", "python"],
    "repository_mount": "read-only",
    "command": "./tools/render-brand-assets --check",
}, indent=2, sort_keys=True))
PY
}

check() {
    command -v "$runtime" >/dev/null
    "$runtime" run --rm \
        -v "$ROOT:/repo:ro" -w /repo \
        "$COSMIC_ARCH_IMAGE" \
        bash -euo pipefail -c '
            printf "Server = https://archive.archlinux.org/repos/%s/\$repo/os/\$arch\n" \
                "$1" > /etc/pacman.d/mirrorlist
            pacman -Syu --noconfirm --needed imagemagick ffmpeg librsvg python >/dev/null
            ./tools/render-brand-assets --check
        ' _ "$COSMIC_ARCH_SNAPSHOT"
}

render() {
    command -v "$runtime" >/dev/null
    mkdir -p "$ROOT/.sdk/rendered-brand-assets"
    output=$(mktemp -d "$ROOT/.sdk/rendered-brand-assets/output.XXXXXX")
    "$runtime" run --rm \
        -v "$ROOT:/repo:ro" -v "$output:/output" -w /repo \
        "$COSMIC_ARCH_IMAGE" \
        bash -euo pipefail -c '
            printf "Server = https://archive.archlinux.org/repos/%s/\$repo/os/\$arch\n" \
                "$1" > /etc/pacman.d/mirrorlist
            pacman -Syu --noconfirm --needed imagemagick ffmpeg librsvg python >/dev/null
            ./tools/render-brand-assets --output /output
            chmod -R a+rX /output
        ' _ "$COSMIC_ARCH_SNAPSHOT"
    "$ROOT/tools/render-brand-assets" --adopt-output "$output"
}

validate
case ${1:-} in
    plan) [[ $# -eq 1 ]] || { usage; exit 2; }; plan ;;
    check) [[ $# -eq 1 ]] || { usage; exit 2; }; check ;;
    render) [[ $# -eq 1 ]] || { usage; exit 2; }; render ;;
    *) usage; exit 2 ;;
esac
