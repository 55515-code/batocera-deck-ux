#!/usr/bin/env python3
"""Validate and audit LuigiOS community configuration without storing credentials."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import re
import struct
import sys
import urllib.error
import urllib.request
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
COMMUNITY = ROOT / "community"


def load_json(path: Path):
    return json.loads(path.read_text(encoding="utf-8"))


def png_size(path: Path) -> tuple[int, int]:
    data = path.read_bytes()[:24]
    if len(data) != 24 or data[:8] != b"\x89PNG\r\n\x1a\n":
        raise ValueError(f"{path}: expected a PNG")
    return struct.unpack(">II", data[16:24])


def validate() -> dict:
    errors: list[str] = []
    registry = load_json(COMMUNITY / "channels.json")
    reddit = load_json(COMMUNITY / "reddit/community.json")
    discord = (COMMUNITY / "discord/server-blueprint.yml").read_text(encoding="utf-8")

    for platform, link_key in (("discord", "invite"), ("reddit", "url")):
        state = registry[platform]
        if state["status"].startswith("live") and not state.get(link_key):
            errors.append(f"{platform}: live status requires {link_key}")
        if not state["status"].startswith("live") and state.get(link_key):
            errors.append(f"{platform}: non-live status must not publish {link_key}")

    if reddit["name"] != "LuigiOS" or reddit["over_18"]:
        errors.append("reddit: expected the public, non-18+ LuigiOS community")
    if not 3 <= len(reddit["name"]) <= 21:
        errors.append("reddit: name must be 3-21 characters")
    if len(reddit["rules"]) < 5 or len(reddit["post_flair"]) < 5:
        errors.append("reddit: insufficient rules or post flair")
    for post in reddit["seed_posts"]:
        source = ROOT / post["source"]
        if not source.is_file() or len(source.read_text(encoding="utf-8").strip()) < 100:
            errors.append(f"reddit: missing or incomplete seed post {source}")

    defaults = re.search(r"^  default_channels: \[([^]]+)\]$", discord, re.MULTILINE)
    writable = set(re.findall(r"\{name: ([a-z0-9-]+),[^}]*writable: true,[^}]*default: true[^}]*\}", discord))
    default_set = set(x.strip() for x in defaults.group(1).split(",")) if defaults else set()
    if len(default_set) < 7 or len(default_set & writable) < 5:
        errors.append("discord: onboarding needs 7 default and 5 writable default channels")
    for required in ("rules", "start-here", "announcements", "general", "help", "showcase", "hardware-lab", "mod-alerts"):
        if not re.search(rf"\bname: {re.escape(required)}\b", discord):
            errors.append(f"discord: missing channel {required}")

    expected_assets = {
        ROOT / reddit["assets"]["avatar"]: (512, 512),
        ROOT / reddit["assets"]["banner"]: (1920, 480),
    }
    for path, size in expected_assets.items():
        try:
            if png_size(path) != size:
                errors.append(f"asset: {path} has wrong dimensions")
        except (OSError, ValueError) as exc:
            errors.append(str(exc))

    return {"ok": not errors, "errors": errors, "platforms": registry}


def public_probe() -> dict:
    url = "https://www.reddit.com/r/LuigiOS/about.json"
    request = urllib.request.Request(url, headers={"User-Agent": "LuigiOS-community-audit/1.0"})
    result = {"checked_at": dt.datetime.now(dt.timezone.utc).isoformat(), "reddit": {"url": url}}
    try:
        with urllib.request.urlopen(request, timeout=15) as response:
            final_url = response.geturl()
            result["reddit"].update({"http_status": response.status, "final_url": final_url,
                                     "appears_created": "/subreddits/search" not in final_url})
    except urllib.error.HTTPError as exc:
        result["reddit"].update({"http_status": exc.code, "appears_created": None,
                                 "note": "Platform denied an unauthenticated probe"})
    except urllib.error.URLError as exc:
        result["reddit"].update({"appears_created": None, "note": str(exc.reason)})
    return result


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("command", choices=("validate", "audit"))
    parser.add_argument("--write", type=Path, help="write JSON result to this path")
    args = parser.parse_args()
    report = validate()
    if args.command == "audit":
        report["public_probe"] = public_probe()
    output = json.dumps(report, indent=2, sort_keys=True) + "\n"
    if args.write:
        args.write.parent.mkdir(parents=True, exist_ok=True)
        args.write.write_text(output, encoding="utf-8")
    sys.stdout.write(output)
    return 0 if report["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
