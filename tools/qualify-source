#!/usr/bin/env python3
"""Create verifiable QA evidence for an exact LuigiOS source revision."""

import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
DEFAULT_POLICY = ROOT / "profiles/source-qualification-v1.json"
DEFAULT_VERSIONS = ROOT / "sdk/versions.env"
HEX_40 = re.compile(r"^[0-9a-f]{40}$")
DIGEST_IMAGE = re.compile(r"^[^\s@]+@sha256:[0-9a-f]{64}$")
SNAPSHOT = re.compile(r"^20[0-9]{2}/(?:0[1-9]|1[0-2])/(?:0[1-9]|[12][0-9]|3[01])$")


def load_json(path):
    value = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(value, dict):
        raise ValueError(f"{path} must contain a JSON object")
    return value


def load_versions(path):
    values = {}
    for number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if "=" not in stripped:
            raise ValueError(f"{path}:{number}: expected KEY=VALUE")
        key, value = stripped.split("=", 1)
        if not re.fullmatch(r"[A-Z][A-Z0-9_]*", key):
            raise ValueError(f"{path}:{number}: invalid variable name")
        values[key] = value
    return values


def sha256(path):
    digest = hashlib.sha256()
    with path.open("rb") as source:
        for chunk in iter(lambda: source.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def git(root, *args):
    return subprocess.run(
        ["git", *args], cwd=root, check=True, capture_output=True, text=True
    ).stdout.strip()


def package_names(root):
    config = (root / "Config.in").read_text(encoding="utf-8")
    paths = re.findall(r'product/package/([^/]+)/Config\.in"', config)
    if not paths:
        raise ValueError("Config.in does not source any LuigiOS packages")
    return sorted(set(paths))


def inspect_source(root=ROOT, policy_path=DEFAULT_POLICY, versions_path=DEFAULT_VERSIONS):
    policy = load_json(policy_path)
    versions = load_versions(versions_path)
    errors = []

    if policy.get("schema_version") != 1:
        errors.append("source qualification policy schema must be 1")
    if policy.get("authoritative_gate") != "./tools/ci-check":
        errors.append("authoritative source gate must be ./tools/ci-check")
    for key in policy.get("required_pins", []):
        if not versions.get(key):
            errors.append(f"missing required SDK pin {key}")
    if not HEX_40.fullmatch(versions.get("BATOCERA_COMMIT", "")):
        errors.append("BATOCERA_COMMIT must be a full 40-character commit")
    for key in ("BATOCERA_BUILD_IMAGE", "COSMIC_ARCH_IMAGE"):
        if not DIGEST_IMAGE.fullmatch(versions.get(key, "")):
            errors.append(f"{key} must use an immutable sha256 image digest")
    if not SNAPSHOT.fullmatch(versions.get("COSMIC_ARCH_SNAPSHOT", "")):
        errors.append("COSMIC_ARCH_SNAPSHOT must be YYYY/MM/DD")

    for relative in policy.get("required_buildroot_files", []):
        if not (root / relative).is_file():
            errors.append(f"missing Buildroot integration file {relative}")

    packages = package_names(root)
    for package in packages:
        directory = root / "product/package" / package
        for filename in ("Config.in", f"{package}.mk"):
            if not (directory / filename).is_file():
                errors.append(f"{package}: missing {filename}")

    claims = policy.get("claims", {})
    for prohibited in ("end_user_os_image_built", "beta_qualified", "hardware_qualified"):
        if claims.get(prohibited) is not False:
            errors.append(f"source evidence must not claim {prohibited}")

    return {
        "schema_version": 1,
        "policy": policy.get("id"),
        "gate": policy.get("authoritative_gate"),
        "dependency_pins": {key: versions.get(key) for key in policy.get("required_pins", [])},
        "buildroot_packages": packages,
        "claims": claims,
        "errors": errors,
        "ok": not errors,
    }


def source_identity(root):
    return {
        "commit": git(root, "rev-parse", "HEAD"),
        "tree": git(root, "rev-parse", "HEAD^{tree}"),
        "commit_time": git(root, "show", "-s", "--format=%cI", "HEAD"),
        "version": (root / "VERSION").read_text(encoding="utf-8").strip(),
        "clean": not bool(git(root, "status", "--porcelain")),
    }


def write_json(path, value):
    path.write_text(json.dumps(value, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def run_qualification(output, root=ROOT, gate=None):
    inspection = inspect_source(root)
    identity = source_identity(root)
    if not inspection["ok"]:
        raise RuntimeError("source contract failed: " + "; ".join(inspection["errors"]))
    if not identity["clean"]:
        raise RuntimeError("source qualification requires a clean Git worktree")

    output = output.resolve()
    if output.exists():
        raise RuntimeError(f"refusing to replace existing evidence: {output}")
    output.parent.mkdir(parents=True, exist_ok=True)
    temporary = Path(tempfile.mkdtemp(prefix=f".{output.name}.", dir=output.parent))
    gate_log = temporary / "ci-check.log"
    command = gate or [str(root / "tools/ci-check")]
    try:
        with gate_log.open("wb") as log:
            completed = subprocess.run(command, cwd=root, stdout=log, stderr=subprocess.STDOUT)
        report = {
            "schema_version": 1,
            "artifact_kind": "source-qualification",
            "status": "pass" if completed.returncode == 0 else "fail",
            "source": identity,
            "inspection": inspection,
            "gate": {
                "command": ["./tools/ci-check"] if gate is None else list(command),
                "exit_code": completed.returncode,
                "log": gate_log.name,
                "log_sha256": sha256(gate_log),
            },
        }
        write_json(temporary / "report.json", report)
        os.replace(temporary, output)
    except BaseException:
        shutil.rmtree(temporary, ignore_errors=True)
        raise
    return report


def verify_bundle(report_path, root=ROOT, require_current_source=True):
    report_path = report_path / "report.json" if report_path.is_dir() else report_path
    report = load_json(report_path)
    errors = []
    if report.get("schema_version") != 1:
        errors.append("report schema must be 1")
    if report.get("artifact_kind") != "source-qualification":
        errors.append("unexpected artifact kind")
    if report.get("status") != "pass" or report.get("gate", {}).get("exit_code") != 0:
        errors.append("authoritative gate did not pass")
    log = report_path.parent / report.get("gate", {}).get("log", "")
    if not log.is_file():
        errors.append("gate log is missing")
    elif sha256(log) != report.get("gate", {}).get("log_sha256"):
        errors.append("gate log digest mismatch")
    claims = report.get("inspection", {}).get("claims", {})
    if any(claims.get(key) is not False for key in (
        "end_user_os_image_built", "beta_qualified", "hardware_qualified"
    )):
        errors.append("source report overstates product qualification")
    if require_current_source:
        current = source_identity(root)
        recorded = report.get("source", {})
        if recorded.get("commit") != current["commit"] or recorded.get("tree") != current["tree"]:
            errors.append("report does not match the current Git source")
        if not current["clean"]:
            errors.append("current Git worktree is dirty")
        if report.get("inspection", {}).get("dependency_pins") != inspect_source(root)["dependency_pins"]:
            errors.append("dependency pins changed after qualification")
    return errors


def main():
    parser = argparse.ArgumentParser(prog="qualify-source")
    commands = parser.add_subparsers(dest="command", required=True)
    commands.add_parser("plan")
    run = commands.add_parser("run")
    run.add_argument("--output", type=Path)
    verify = commands.add_parser("verify")
    verify.add_argument("report", type=Path)
    verify.add_argument("--detached", action="store_true", help="verify evidence without requiring its source checkout")
    args = parser.parse_args()

    if args.command == "plan":
        result = inspect_source()
        print(json.dumps(result, indent=2, sort_keys=True))
        return 0 if result["ok"] else 1
    if args.command == "run":
        identity = source_identity(ROOT)
        output = args.output or ROOT / "dist/qualification" / identity["commit"]
        try:
            result = run_qualification(output)
        except (OSError, ValueError, RuntimeError, subprocess.CalledProcessError) as error:
            print(str(error), file=sys.stderr)
            return 1
        print(output)
        return 0 if result["status"] == "pass" else 1

    errors = verify_bundle(args.report, require_current_source=not args.detached)
    print(json.dumps({"ok": not errors, "errors": errors}, indent=2, sort_keys=True))
    return 1 if errors else 0


if __name__ == "__main__":
    raise SystemExit(main())
