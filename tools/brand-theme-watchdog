#!/bin/sh
set -eu

backup=${1:?backup directory is required}
target=${2:?theme target is required}
delay=${LUIGIOS_WATCHDOG_DELAY:-60}

sleep "$delay"
test -f "$backup/confirmed" && exit 0

failed="${target}.failed-$(date -u +%Y%m%d-%H%M%S)"
test ! -e "$failed"
mv "$target" "$failed"
mv "$backup/theme" "$target"
batocera-es-swissknife --restart
