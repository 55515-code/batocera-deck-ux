#!/usr/bin/env python3
"""Validate the pinned LuigiOS COSMIC desktop artifact contract."""

from __future__ import annotations

import argparse
import json
import pathlib
import re
import sys


ROOT = pathlib.Path(__file__).resolve().parents[1]
DEFAULT_MANIFEST = ROOT / "product/desktop/cosmic-image-v1.json"
PACKAGE_PATTERN = re.compile(r"^[a-z0-9][a-z0-9@._+-]*$")


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--manifest", type=pathlib.Path, default=DEFAULT_MANIFEST)
    commands = parser.add_subparsers(dest="command", required=True)
    commands.add_parser("validate")
    preflight = commands.add_parser("preflight")
    preflight.add_argument("--root", type=pathlib.Path, required=True)
    preflight.add_argument("--allow-unattested", action="store_true")
    preflight.add_argument("--format", choices=("human", "json"), default="human")
    migration = commands.add_parser("migration-plan")
    migration.add_argument("--format", choices=("human", "json"), default="human")
    return parser.parse_args(argv)


def load_manifest(path: pathlib.Path) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
        raise ValueError(f"cannot read COSMIC image contract {path}: {error}") from error
    if not isinstance(value, dict):
        raise ValueError("COSMIC image contract must be an object")
    return value


def contract_errors(manifest: dict) -> list[str]:
    errors = []
    if manifest.get("schema_version") != 1:
        errors.append("schema_version must be 1")
    if manifest.get("architecture") != "x86_64":
        errors.append("architecture must be x86_64")
    desktop = manifest.get("desktop")
    if not isinstance(desktop, dict) or desktop.get("name") != "COSMIC":
        errors.append("desktop.name must be COSMIC")
    if not isinstance(desktop, dict) or desktop.get("backend") != "winit":
        errors.append("desktop.backend must be winit")
    paths = manifest.get("paths")
    for name in ("rootfs", "home", "previous_plasma_home"):
        value = paths.get(name) if isinstance(paths, dict) else None
        if not isinstance(value, str) or not value.startswith("/") or ".." in pathlib.PurePosixPath(value).parts:
            errors.append(f"paths.{name} must be a safe absolute path")
    packages = manifest.get("required_packages")
    if not isinstance(packages, list) or not packages:
        errors.append("required_packages must be a non-empty list")
    elif packages != sorted(set(packages)):
        errors.append("required_packages must be sorted and unique")
    elif any(not isinstance(item, str) or not PACKAGE_PATTERN.fullmatch(item) for item in packages):
        errors.append("required_packages contains an invalid package name")
    executables = manifest.get("required_executables")
    if not isinstance(executables, list) or not executables:
        errors.append("required_executables must be a non-empty list")
    elif executables != sorted(set(executables)):
        errors.append("required_executables must be sorted and unique")
    elif any(not isinstance(item, str) or not item.startswith("/usr/") or ".." in pathlib.PurePosixPath(item).parts for item in executables):
        errors.append("required_executables contains an unsafe path")
    migration = manifest.get("migration")
    if not isinstance(migration, dict):
        errors.append("migration must be an object")
    else:
        copied = migration.get("copy_if_present")
        blocked = migration.get("never_copy")
        if not all(isinstance(items, list) for items in (copied, blocked)):
            errors.append("migration lists must be arrays")
        elif set(copied) & set(blocked):
            errors.append("migration copy and exclusion lists overlap")
    return errors


def package_version(root: pathlib.Path, package: str) -> str | None:
    database = root / "var/lib/pacman/local"
    candidates = sorted(database.glob(f"{package}-*/desc"))
    for desc in reversed(candidates):
        try:
            lines = desc.read_text(encoding="utf-8").splitlines()
        except (OSError, UnicodeDecodeError):
            continue
        fields = {}
        for index, line in enumerate(lines[:-1]):
            if line.startswith("%") and line.endswith("%"):
                fields[line] = lines[index + 1]
        if fields.get("%NAME%") == package:
            return fields.get("%VERSION%")
    return None


def normalized_version(value: str) -> tuple[int, ...]:
    upstream = value.split(":", 1)[-1].split("-", 1)[0]
    numbers = re.findall(r"\d+", upstream)
    return tuple(int(number) for number in numbers[:3])


def preflight(root: pathlib.Path, manifest: dict, allow_unattested: bool) -> dict:
    errors = []
    warnings = []
    packages = {}
    if not root.is_dir() or root.is_symlink():
        errors.append(f"rootfs is missing or unsafe: {root}")
    else:
        for executable in manifest["required_executables"]:
            path = root / executable.lstrip("/")
            if not path.is_file() or path.is_symlink() or not path.stat().st_mode & 0o111:
                errors.append(f"required executable is missing or unsafe: {executable}")
        for package in manifest["required_packages"]:
            version = package_version(root, package)
            packages[package] = version
            if version is None:
                errors.append(f"required Arch package is absent: {package}")
        floor = normalized_version(manifest["desktop"]["version_floor"])
        for package in ("cosmic-comp", "cosmic-session"):
            version = packages.get(package)
            if version and normalized_version(version) < floor:
                errors.append(f"{package} {version} is below {manifest['desktop']['version_floor']}")
        passwd = root / "etc/passwd"
        try:
            deck_users = [line for line in passwd.read_text().splitlines() if line.startswith("deck:")]
        except OSError:
            deck_users = []
        if len(deck_users) != 1 or deck_users[0].split(":")[2:4] != ["1000", "1000"]:
            errors.append("rootfs must contain exactly one deck user with UID/GID 1000")
        for label, path in manifest["attestation"].items():
            target = root / path.lstrip("/")
            if not target.is_file() or target.is_symlink():
                message = f"artifact {label} is absent: {path}"
                (warnings if allow_unattested else errors).append(message)
    return {
        "schema_version": 1,
        "contract": manifest["id"],
        "root": str(root.resolve()),
        "packages": packages,
        "errors": sorted(errors),
        "warnings": sorted(warnings),
        "valid": not errors,
    }


def migration_plan(manifest: dict) -> dict:
    paths = manifest["paths"]
    return {
        "schema_version": 1,
        "source": paths["previous_plasma_home"],
        "destination": paths["home"],
        "copy_if_present": manifest["migration"]["copy_if_present"],
        "never_copy": manifest["migration"]["never_copy"],
        "automatic": False,
        "reason": "Migration requires a backup and an explicit transaction after COSMIC preflight passes."
    }


def emit(report: dict, style: str = "human") -> None:
    if style == "json":
        print(json.dumps(report, indent=2, sort_keys=True))
        return
    for error in report.get("errors", []):
        print(f"ERROR: {error}")
    for warning in report.get("warnings", []):
        print(f"WARNING: {warning}")
    if "valid" in report:
        print(f"COSMIC image: {'PASS' if report['valid'] else 'FAIL'}")
    else:
        print(json.dumps(report, indent=2, sort_keys=True))


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    try:
        manifest = load_manifest(args.manifest)
    except ValueError as error:
        print(error, file=sys.stderr)
        return 1
    errors = contract_errors(manifest)
    if errors:
        emit({"valid": False, "errors": errors})
        return 1
    if args.command == "validate":
        emit({"valid": True, "errors": []})
        return 0
    if args.command == "migration-plan":
        emit(migration_plan(manifest), args.format)
        return 0
    report = preflight(args.root, manifest, args.allow_unattested)
    emit(report, args.format)
    return 0 if report["valid"] else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
