#!/usr/bin/env bash
set -euo pipefail

ROOT=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
# shellcheck source=../sdk/versions.env
source "$ROOT/sdk/versions.env"

MANIFEST=${COSMIC_MANIFEST:-"$ROOT/product/desktop/cosmic-image-v1.json"}
OUTPUT_ROOT=${COSMIC_OUTPUT_ROOT:-"$ROOT/dist/cosmic"}
RUNTIME=${CONTAINER_RUNTIME:-podman}
APPLY=false

usage() {
    cat <<'EOF'
Usage: ./tools/build-cosmic-image plan
       ./tools/build-cosmic-image build --apply

Builds an Arch Archive-pinned COSMIC rootfs locally. It never deploys to a device.
EOF
}

[[ ${COSMIC_ARCH_IMAGE:-} == *@sha256:* ]] || {
    echo "COSMIC_ARCH_IMAGE must use an immutable sha256 digest" >&2
    exit 1
}
[[ ${COSMIC_ARCH_SNAPSHOT:-} =~ ^20[0-9]{2}/(0[1-9]|1[0-2])/(0[1-9]|[12][0-9]|3[01])$ ]] || {
    echo "COSMIC_ARCH_SNAPSHOT must be YYYY/MM/DD" >&2
    exit 1
}

mapfile -t PACKAGES < <(python3 - "$MANIFEST" <<'PY'
import json
import pathlib
import sys

manifest = json.loads(pathlib.Path(sys.argv[1]).read_text())
for package in manifest["required_packages"]:
    print(package)
PY
)
CONTRACT=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["id"])' "$MANIFEST")
ARTIFACT_DIR="$OUTPUT_ROOT/$CONTRACT"
CACHE_DIR="$OUTPUT_ROOT/.cache/${COSMIC_ARCH_SNAPSHOT//\//-}"

plan() {
    python3 - "$CONTRACT" "$COSMIC_ARCH_IMAGE" "$COSMIC_ARCH_SNAPSHOT" "$ARTIFACT_DIR" "${PACKAGES[@]}" <<'PY'
import json
import sys

print(json.dumps({
    "schema_version": 1,
    "contract": sys.argv[1],
    "base_image": sys.argv[2],
    "arch_snapshot": sys.argv[3],
    "output": sys.argv[4],
    "packages": sys.argv[5:],
    "device_mutation": False,
}, indent=2, sort_keys=True))
PY
}

build() {
    [[ $APPLY == true ]] || {
        plan
        echo "dry run; pass --apply to build" >&2
        return 2
    }
    command -v "$RUNTIME" >/dev/null
    command -v zstd >/dev/null
    "$ROOT/tools/cosmic-image" --manifest "$MANIFEST" validate

    mkdir -p "$OUTPUT_ROOT" "$CACHE_DIR"
    work=$(mktemp -d "$OUTPUT_ROOT/.build.XXXXXX")
    container="luigios-cosmic-build-$$"
    complete=false
    cleanup() {
        "$RUNTIME" rm -f "$container" >/dev/null 2>&1 || true
        if [[ $complete != true ]]; then
            chmod -R u+rwX "$work" 2>/dev/null || true
            rm -rf -- "$work"
        fi
    }
    trap cleanup EXIT INT TERM HUP

    "$RUNTIME" pull "$COSMIC_ARCH_IMAGE"
    "$RUNTIME" create --name "$container" \
        --volume "$CACHE_DIR:/var/cache/pacman/pkg:Z" \
        "$COSMIC_ARCH_IMAGE" sleep infinity >/dev/null
    "$RUNTIME" start "$container" >/dev/null
    "$RUNTIME" exec "$container" bash -euo pipefail -c \
        'printf "Server = https://archive.archlinux.org/repos/%s/\$repo/os/\$arch\n" "$1" > /etc/pacman.d/mirrorlist' \
        _ "$COSMIC_ARCH_SNAPSHOT"
    "$RUNTIME" exec "$container" pacman -Syu --noconfirm --needed "${PACKAGES[@]}"
    "$RUNTIME" exec "$container" bash -euo pipefail -c '
        getent group deck >/dev/null || groupadd --gid 1000 deck
        id deck >/dev/null 2>&1 || useradd --uid 1000 --gid 1000 --create-home \
            --home-dir /home/deck --shell /bin/bash --comment "LuigiOS Desktop" deck
        install -d -o 1000 -g 1000 -m 0700 /home/deck
        rm -f /etc/machine-id /var/lib/dbus/machine-id
        : > /etc/machine-id
    '
    "$RUNTIME" exec "$container" pacman -Q >"$work/packages.txt"
    mkdir "$work/attestations"
    python3 - "$work/packages.txt" "$work/attestations" "$MANIFEST" \
        "$COSMIC_ARCH_IMAGE" "$COSMIC_ARCH_SNAPSHOT" <<'PY'
import json
import pathlib
import sys

package_list = pathlib.Path(sys.argv[1])
target = pathlib.Path(sys.argv[2])
manifest = json.loads(pathlib.Path(sys.argv[3]).read_text())
packages = [
    {"name": line.split(" ", 1)[0], "version": line.split(" ", 1)[1]}
    for line in package_list.read_text().splitlines()
]
build = {
    "schema_version": 1,
    "contract": manifest["id"],
    "base_image": sys.argv[4],
    "arch_snapshot": sys.argv[5],
    "packages": packages,
}
(target / "cosmic-image-build.json").write_text(json.dumps(build, indent=2, sort_keys=True) + "\n")
sbom = {
    "spdxVersion": "SPDX-2.3",
    "dataLicense": "CC0-1.0",
    "SPDXID": "SPDXRef-DOCUMENT",
    "name": manifest["id"],
    "documentNamespace": f"https://luigios.invalid/spdx/{manifest['id']}/{sys.argv[5].replace('/', '-')}",
    "creationInfo": {
        "created": sys.argv[5].replace("/", "-") + "T00:00:00Z",
        "creators": ["Tool: LuigiOS-tools-build-cosmic-image"],
    },
    "packages": [
        {
            "name": item["name"],
            "SPDXID": "SPDXRef-Package-" + item["name"].replace("+", "-").replace(".", "-"),
            "versionInfo": item["version"],
            "downloadLocation": "NOASSERTION",
            "filesAnalyzed": False,
            "licenseConcluded": "NOASSERTION",
            "licenseDeclared": "NOASSERTION",
            "copyrightText": "NOASSERTION",
        }
        for item in packages
    ],
}
(target / "cosmic-image.spdx.json").write_text(json.dumps(sbom, indent=2, sort_keys=True) + "\n")
PY
    "$RUNTIME" exec "$container" install -d -m 0755 /usr/share/luigios
    "$RUNTIME" cp "$work/attestations/cosmic-image-build.json" \
        "$container:/usr/share/luigios/cosmic-image-build.json"
    "$RUNTIME" cp "$work/attestations/cosmic-image.spdx.json" \
        "$container:/usr/share/luigios/cosmic-image.spdx.json"

    epoch=$(TZ=UTC date -d "${COSMIC_ARCH_SNAPSHOT//\//-} 00:00:00" +%s)
    "$RUNTIME" exec "$container" tar --sort=name --mtime="@$epoch" --clamp-mtime \
        --numeric-owner --xattrs --acls \
        --exclude='./dev' --exclude='./proc' --exclude='./run' --exclude='./sys' \
        --exclude='./var/cache/pacman/pkg' \
        -C / -cf - . | zstd -T0 -10 -o "$work/rootfs.tar.zst"

    mkdir "$work/rootfs"
    zstd -dc "$work/rootfs.tar.zst" |
        tar --no-same-owner --no-same-permissions -C "$work/rootfs" -xf -
    "$ROOT/tools/cosmic-image" --manifest "$MANIFEST" preflight \
        --root "$work/rootfs" --format json >"$work/preflight.json"
    chmod -R u+rwX "$work/rootfs"
    rm -rf -- "$work/rootfs" "$work/attestations" "$work/packages.txt"
    (cd "$work" && sha256sum rootfs.tar.zst >rootfs.tar.zst.sha256)
    cp "$MANIFEST" "$work/contract.json"

    rm -rf -- "$ARTIFACT_DIR"
    mv "$work" "$ARTIFACT_DIR"
    complete=true
    trap - EXIT INT TERM HUP
    "$RUNTIME" rm -f "$container" >/dev/null 2>&1 || true
    printf 'COSMIC artifact: %s\n' "$ARTIFACT_DIR"
}

case ${1:-} in
    plan) [[ $# -eq 1 ]] || { usage; exit 2; }; plan ;;
    build)
        shift
        [[ ${1:-} == --apply && $# -eq 1 ]] || { plan; echo "dry run; pass --apply to build" >&2; exit 2; }
        APPLY=true
        build
        ;;
    *) usage; exit 2 ;;
esac
