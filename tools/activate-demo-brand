#!/usr/bin/env python3
"""Atomically activate or roll back LuigiOS demo branding."""

from __future__ import annotations

import argparse
from datetime import datetime, timezone
import json
import os
from pathlib import Path
import shutil
import stat
import tempfile
import xml.etree.ElementTree as ET


ES_SETTINGS = "/userdata/system/configs/emulationstation/es_settings.cfg"
ES_THEME = "/userdata/themes/luigios/theme.xml"
DESKTOP_HOME = "/userdata/system/containers/arch-plasma/home/deck"
PLASMA_CONFIG = ".config/plasma-org.kde.plasma.desktop-appletsrc"
WALLPAPER = ".local/share/backgrounds/luigios/1280x800.png"
WALLPAPER_SECTION = "[Containments][1][Wallpaper][org.kde.image][General]"


def rooted(root: Path, path: str) -> Path:
    return root / path.lstrip("/")


def atomic_write(path: Path, content: bytes, metadata_from: Path | None = None) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    metadata = (metadata_from or path).stat() if (metadata_from or path).exists() else None
    descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temporary = Path(temporary_name)
    try:
        with os.fdopen(descriptor, "wb") as stream:
            if metadata is not None:
                os.fchmod(stream.fileno(), stat.S_IMODE(metadata.st_mode))
                os.fchown(stream.fileno(), metadata.st_uid, metadata.st_gid)
            stream.write(content)
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def es_with_theme(content: bytes, theme: str) -> bytes:
    root = ET.fromstring(content)
    setting = root.find(".//string[@name='ThemeSet']")
    if setting is None:
        setting = ET.SubElement(root, "string", {"name": "ThemeSet"})
    setting.set("value", theme)
    return ET.tostring(root, encoding="utf-8", xml_declaration=True)


def kconfig_with_wallpaper(content: str, image: str) -> str:
    lines = content.splitlines()
    section_start = None
    section_end = len(lines)
    for index, line in enumerate(lines):
        if line == WALLPAPER_SECTION:
            section_start = index
            continue
        if section_start is not None and index > section_start and line.startswith("["):
            section_end = index
            break
    values = [f"Image=file://{image}", "FillMode=2"]
    if section_start is None:
        if lines and lines[-1]:
            lines.append("")
        lines.extend([WALLPAPER_SECTION, *values])
    else:
        kept = [
            line for line in lines[section_start + 1 : section_end]
            if not line.startswith(("Image=", "FillMode="))
        ]
        lines[section_start + 1 : section_end] = [*kept, *values]
    return "\n".join(lines) + "\n"


def apply(args: argparse.Namespace) -> int:
    root = args.root.resolve()
    es = rooted(root, ES_SETTINGS)
    theme = rooted(root, ES_THEME)
    home = rooted(root, args.desktop_home)
    plasma = home / PLASMA_CONFIG
    wallpaper = home / WALLPAPER
    for path in (es, theme, plasma, wallpaper):
        if not path.is_file() or path.is_symlink():
            raise ValueError(f"required regular file is missing: {path}")
    updated_es = es_with_theme(es.read_bytes(), args.theme)
    updated_plasma = kconfig_with_wallpaper(
        plasma.read_text(encoding="utf-8"), f"/home/deck/{WALLPAPER}"
    ).encode()
    print(f"ThemeSet={args.theme}")
    print(f"Wallpaper=/home/deck/{WALLPAPER}")
    if not args.apply:
        print("dry run; pass --apply to activate")
        return 0

    stamp = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
    backup = rooted(root, f"/userdata/system/backups/luigios-activation-{stamp}")
    backup.mkdir(parents=True, exist_ok=False)
    files = [(es, "es_settings.cfg", updated_es), (plasma, "plasma-appletsrc", updated_plasma)]
    record = {"schema_version": 1, "created_at_utc": stamp, "files": []}
    for target, name, replacement in files:
        saved = backup / name
        shutil.copy2(target, saved)
        record["files"].append({"target": str(target.relative_to(root)), "backup": name})
        atomic_write(target, replacement)
    atomic_write(backup / "activation.json", (json.dumps(record, indent=2) + "\n").encode())
    print(f"backup={backup}")
    return 0


def rollback(args: argparse.Namespace) -> int:
    root = args.root.resolve()
    backup = args.backup.resolve()
    record = json.loads((backup / "activation.json").read_text(encoding="utf-8"))
    for item in record["files"]:
        target = root / item["target"]
        saved = backup / item["backup"]
        if not saved.is_file() or saved.is_symlink():
            raise ValueError(f"invalid backup file: {saved}")
        atomic_write(target, saved.read_bytes(), metadata_from=saved)
        print(f"restored={target}")
    return 0


def parser() -> argparse.ArgumentParser:
    result = argparse.ArgumentParser(prog="activate-demo-brand")
    result.add_argument("--root", type=Path, default=Path("/"))
    commands = result.add_subparsers(dest="command", required=True)
    activate = commands.add_parser("activate")
    activate.add_argument("--desktop-home", default=DESKTOP_HOME)
    activate.add_argument("--theme", default="luigios")
    activate.add_argument("--apply", action="store_true")
    activate.set_defaults(function=apply)
    restore = commands.add_parser("rollback")
    restore.add_argument("--backup", type=Path, required=True)
    restore.set_defaults(function=rollback)
    return result


def main() -> int:
    try:
        args = parser().parse_args()
        return args.function(args)
    except (OSError, ValueError, KeyError, ET.ParseError, json.JSONDecodeError) as error:
        print(f"activate-demo-brand: {error}")
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
