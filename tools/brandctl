#!/usr/bin/env python3
"""Validate, plan, and transactionally deploy LuigiOS brand assets."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import pathlib
import re
import shutil
import struct
import sys
import tempfile
import time
import xml.etree.ElementTree as ET
from dataclasses import dataclass


ROOT = pathlib.Path(__file__).resolve().parents[1]
DEFAULT_MANIFEST = ROOT / "branding/brand-v1.json"
ID_PATTERN = re.compile(r"^[a-z0-9]+(?:[.-][a-z0-9]+)*$")
ALLOWED_SCOPES = {"demo", "image"}
DEMO_ROOTS = ("/userdata/",)
IMAGE_ROOTS = ("/usr/share/", "/etc/")


@dataclass
class Report:
    errors: list[str]
    warnings: list[str]
    present: list[str]
    missing_required: list[str]
    missing_optional: list[str]

    @property
    def valid(self) -> bool:
        return not self.errors


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--manifest", type=pathlib.Path, default=DEFAULT_MANIFEST)
    subparsers = parser.add_subparsers(dest="command", required=True)

    validate = subparsers.add_parser("validate")
    validate.add_argument("--require-ready", action="store_true")
    validate.add_argument("--require-provenance", action="store_true")
    validate.add_argument("--format", choices=("human", "json"), default="human")

    plan = subparsers.add_parser("plan")
    plan.add_argument("--scope", choices=sorted(ALLOWED_SCOPES), required=True)
    plan.add_argument(
        "--plasma-home",
        default="/userdata/system/containers/arch-plasma/home/deck",
    )
    plan.add_argument("--format", choices=("human", "json"), default="human")

    identity = subparsers.add_parser("identity")
    identity.add_argument("--root", type=pathlib.Path, default=pathlib.Path("/"))
    identity.add_argument("--apply", action="store_true")

    deploy = subparsers.add_parser("deploy")
    deploy.add_argument("--scope", choices=sorted(ALLOWED_SCOPES), required=True)
    deploy.add_argument("--root", type=pathlib.Path, default=pathlib.Path("/"))
    deploy.add_argument(
        "--plasma-home",
        default="/userdata/system/containers/arch-plasma/home/deck",
    )
    deploy.add_argument("--allow-incomplete", action="store_true")
    deploy.add_argument("--apply", action="store_true")
    return parser.parse_args(argv)


def load_manifest(path: pathlib.Path) -> dict:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
        raise ValueError(f"cannot read brand manifest {path}: {error}") from error
    if not isinstance(data, dict):
        raise ValueError("brand manifest must contain a JSON object")
    return data


def safe_source(base: pathlib.Path, source: object) -> pathlib.Path | None:
    if not isinstance(source, str) or not source:
        return None
    relative = pathlib.PurePosixPath(source)
    if relative.is_absolute() or ".." in relative.parts:
        return None
    return base / pathlib.Path(*relative.parts)


def resolved_destination(raw: object, plasma_home: str) -> str | None:
    if not isinstance(raw, str) or not raw:
        return None
    destination = raw.replace("${PLASMA_HOME}", plasma_home)
    path = pathlib.PurePosixPath(destination)
    if not path.is_absolute() or ".." in path.parts:
        return None
    return str(path)


def destination_allowed(scope: str, destination: str) -> bool:
    roots = DEMO_ROOTS if scope == "demo" else IMAGE_ROOTS
    return any(destination.startswith(root) for root in roots)


def png_dimensions(path: pathlib.Path) -> tuple[int, int]:
    header = path.read_bytes()[:24]
    if len(header) != 24 or header[:8] != b"\x89PNG\r\n\x1a\n" or header[12:16] != b"IHDR":
        raise ValueError("not a valid PNG header")
    return struct.unpack(">II", header[16:24])


def validate_existing_asset(path: pathlib.Path, slot: dict, report: Report) -> None:
    expected_kind = slot.get("kind")
    if path.is_symlink():
        report.errors.append(f"{slot['id']}: source must not be a symlink")
        return
    if expected_kind == "file" and not path.is_file():
        report.errors.append(f"{slot['id']}: expected a regular file at {path}")
        return
    if expected_kind == "directory" and not path.is_dir():
        report.errors.append(f"{slot['id']}: expected a directory at {path}")
        return
    if path.is_file() and path.stat().st_size == 0:
        report.errors.append(f"{slot['id']}: asset is empty")
        return
    if path.is_dir():
        descendants = list(path.rglob("*"))
        if not any(item.is_file() for item in descendants):
            report.errors.append(f"{slot['id']}: asset directory contains no files")
        if any(item.is_symlink() for item in descendants):
            report.errors.append(f"{slot['id']}: asset directory contains a symlink")
        return

    suffix = path.suffix.lower()
    constraints = slot.get("constraints", {})
    if suffix == ".png":
        try:
            width, height = png_dimensions(path)
        except (OSError, ValueError) as error:
            report.errors.append(f"{slot['id']}: {error}")
            return
        expected = (constraints.get("width"), constraints.get("height"))
        if all(isinstance(value, int) for value in expected) and (width, height) != expected:
            report.errors.append(
                f"{slot['id']}: PNG is {width}x{height}, expected {expected[0]}x{expected[1]}"
            )
    elif suffix == ".svg":
        try:
            root = ET.parse(path).getroot()
        except (OSError, ET.ParseError) as error:
            report.errors.append(f"{slot['id']}: invalid SVG: {error}")
            return
        if not root.tag.endswith("svg"):
            report.errors.append(f"{slot['id']}: XML root is not svg")


def validate_manifest(
    manifest_path: pathlib.Path,
    manifest: dict,
    plasma_home: str = "/userdata/system/containers/arch-plasma/home/deck",
    require_provenance: bool = False,
) -> Report:
    report = Report([], [], [], [], [])
    if manifest.get("schema_version") != 1:
        report.errors.append("schema_version must be 1")
    product = manifest.get("product")
    if not isinstance(product, dict) or product.get("display_name") != "LuigiOS":
        report.errors.append("product.display_name must be LuigiOS")
    if not isinstance(product, dict) or product.get("id") != "luigios":
        report.errors.append("product.id must be luigios")

    slots = manifest.get("slots")
    if not isinstance(slots, list) or not slots:
        report.errors.append("slots must be a non-empty list")
        return report

    identifiers: set[str] = set()
    destinations: set[tuple[str, str]] = set()
    for position, slot in enumerate(slots):
        if not isinstance(slot, dict):
            report.errors.append(f"slot {position}: must be an object")
            continue
        identifier = slot.get("id")
        if not isinstance(identifier, str) or not ID_PATTERN.fullmatch(identifier):
            report.errors.append(f"slot {position}: invalid id")
            continue
        if identifier in identifiers:
            report.errors.append(f"{identifier}: duplicate slot id")
        identifiers.add(identifier)
        if slot.get("kind") not in {"file", "directory"}:
            report.errors.append(f"{identifier}: kind must be file or directory")
        source = safe_source(manifest_path.parent, slot.get("source"))
        if source is None:
            report.errors.append(f"{identifier}: source must be a safe relative path")
        elif source.exists() or source.is_symlink():
            report.present.append(identifier)
            validate_existing_asset(source, slot, report)
            if require_provenance:
                provenance = source.parent / "PROVENANCE.json" if source.is_file() else source / "PROVENANCE.json"
                if not provenance.is_file():
                    report.errors.append(f"{identifier}: missing PROVENANCE.json")
        elif slot.get("required_for_demo") is True:
            report.missing_required.append(identifier)
        else:
            report.missing_optional.append(identifier)

        deployments = slot.get("deploy")
        if not isinstance(deployments, list) or not deployments:
            report.errors.append(f"{identifier}: deploy must be a non-empty list")
            continue
        for deployment in deployments:
            if not isinstance(deployment, dict):
                report.errors.append(f"{identifier}: deployment must be an object")
                continue
            scope = deployment.get("scope")
            destination = resolved_destination(deployment.get("destination"), plasma_home)
            if scope not in ALLOWED_SCOPES or destination is None:
                report.errors.append(f"{identifier}: invalid deployment")
                continue
            if not destination_allowed(scope, destination):
                report.errors.append(f"{identifier}: destination outside {scope} roots: {destination}")
            key = (scope, destination)
            if key in destinations:
                report.errors.append(f"{identifier}: duplicate destination {scope}:{destination}")
            destinations.add(key)
    return report


def asset_digest(path: pathlib.Path) -> str:
    digest = hashlib.sha256()
    if path.is_file():
        digest.update(path.read_bytes())
    else:
        for item in sorted(path.rglob("*")):
            if not item.is_file():
                continue
            digest.update(str(item.relative_to(path)).encode())
            digest.update(b"\0")
            digest.update(item.read_bytes())
    return digest.hexdigest()


def operations(manifest_path: pathlib.Path, manifest: dict, scope: str, plasma_home: str) -> list[dict]:
    result = []
    for slot in manifest["slots"]:
        source = safe_source(manifest_path.parent, slot["source"])
        for deployment in slot["deploy"]:
            if deployment["scope"] != scope:
                continue
            result.append(
                {
                    "id": slot["id"],
                    "source": str(source),
                    "destination": resolved_destination(deployment["destination"], plasma_home),
                    "present": bool(source and source.exists()),
                    "digest": asset_digest(source) if source and source.exists() else None,
                }
            )
    return result


def rooted(root: pathlib.Path, destination: str) -> pathlib.Path:
    return root / destination.lstrip("/")


def atomic_write(path: pathlib.Path, content: bytes) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temporary = pathlib.Path(temporary_name)
    try:
        with os.fdopen(descriptor, "wb") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def identity_payload(manifest: dict) -> bytes:
    payload = {
        "schema_version": 1,
        "name": manifest["product"]["display_name"],
        "id": manifest["product"]["id"],
        "variant": manifest["product"]["variant"],
        "upstream": "Batocera",
    }
    return (json.dumps(payload, indent=2, sort_keys=True) + "\n").encode()


def install_identity(root: pathlib.Path, manifest_path: pathlib.Path, manifest: dict, apply: bool) -> int:
    identity = rooted(root, "/userdata/system/configs/luigios/identity.json")
    deployed_manifest = rooted(root, "/userdata/system/configs/luigios/brand-v1.json")
    print(f"identity -> {identity}")
    print(f"manifest -> {deployed_manifest}")
    if not apply:
        print("dry run; pass --apply to write")
        return 0
    atomic_write(identity, identity_payload(manifest))
    atomic_write(deployed_manifest, manifest_path.read_bytes())
    return 0


def deploy_assets(
    root: pathlib.Path,
    manifest_path: pathlib.Path,
    manifest: dict,
    scope: str,
    plasma_home: str,
    allow_incomplete: bool,
    apply: bool,
) -> int:
    if scope == "image" and apply:
        print("image-scope assets must be installed by the reproducible image build", file=sys.stderr)
        return 1
    report = validate_manifest(manifest_path, manifest, plasma_home)
    if report.errors:
        for error in report.errors:
            print(f"error: {error}", file=sys.stderr)
        return 1
    if report.missing_required and not allow_incomplete:
        print("required demo assets are missing; refusing deployment", file=sys.stderr)
        return 2
    planned = [item for item in operations(manifest_path, manifest, scope, plasma_home) if item["present"]]
    for item in planned:
        print(f"{item['id']}: {item['source']} -> {item['destination']}")
    if not apply:
        print("dry run; pass --apply to deploy")
        return 0

    timestamp = time.strftime("%Y%m%d-%H%M%S", time.gmtime())
    backup = rooted(root, f"/userdata/system/backups/luigios-branding-{timestamp}")
    backup.mkdir(parents=True, exist_ok=False)
    changed: list[tuple[pathlib.Path, pathlib.Path | None]] = []
    try:
        for item in planned:
            source = pathlib.Path(item["source"])
            target = rooted(root, item["destination"])
            saved = backup / item["destination"].lstrip("/")
            if target.exists() or target.is_symlink():
                saved.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(target, saved)
                previous = saved
            else:
                previous = None
            target.parent.mkdir(parents=True, exist_ok=True)
            if source.is_dir():
                shutil.copytree(source, target, symlinks=False)
            else:
                temporary = target.with_name(f".{target.name}.luigios-new")
                shutil.copy2(source, temporary)
                os.replace(temporary, target)
            changed.append((target, previous))
        record = {
            "schema_version": 1,
            "scope": scope,
            "deployed_at_utc": timestamp,
            "operations": planned,
        }
        atomic_write(backup / "deployment.json", (json.dumps(record, indent=2) + "\n").encode())
        install_identity(root, manifest_path, manifest, True)
    except Exception:
        for target, previous in reversed(changed):
            if target.is_dir():
                shutil.rmtree(target)
            else:
                target.unlink(missing_ok=True)
            if previous is not None:
                target.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(previous, target)
        raise
    print(f"backup: {backup}")
    return 0


def print_report(report: Report, output_format: str) -> None:
    payload = {
        "valid": report.valid,
        "errors": report.errors,
        "warnings": report.warnings,
        "present": report.present,
        "missing_required": report.missing_required,
        "missing_optional": report.missing_optional,
    }
    if output_format == "json":
        print(json.dumps(payload, indent=2, sort_keys=True))
        return
    print(f"Brand contract: {'VALID' if report.valid else 'INVALID'}")
    print(f"Present: {len(report.present)}")
    print(f"Missing required: {', '.join(report.missing_required) or 'none'}")
    print(f"Missing optional: {', '.join(report.missing_optional) or 'none'}")
    for error in report.errors:
        print(f"ERROR: {error}")


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    try:
        manifest = load_manifest(args.manifest)
    except ValueError as error:
        print(f"error: {error}", file=sys.stderr)
        return 1

    if args.command == "validate":
        report = validate_manifest(args.manifest, manifest, require_provenance=args.require_provenance)
        print_report(report, args.format)
        if not report.valid:
            return 1
        if args.require_ready and report.missing_required:
            return 2
        return 0
    if args.command == "plan":
        report = validate_manifest(args.manifest, manifest, args.plasma_home)
        if not report.valid:
            print_report(report, args.format)
            return 1
        planned = operations(args.manifest, manifest, args.scope, args.plasma_home)
        if args.format == "json":
            print(json.dumps(planned, indent=2, sort_keys=True))
        else:
            for item in planned:
                state = "ready" if item["present"] else "missing"
                print(f"[{state:7}] {item['id']}: {item['destination']}")
        return 0
    if args.command == "identity":
        report = validate_manifest(args.manifest, manifest)
        if not report.valid:
            print_report(report, "human")
            return 1
        return install_identity(args.root, args.manifest, manifest, args.apply)
    if args.command == "deploy":
        return deploy_assets(
            args.root,
            args.manifest,
            manifest,
            args.scope,
            args.plasma_home,
            args.allow_incomplete,
            args.apply,
        )
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
