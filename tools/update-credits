#!/usr/bin/env python3
import argparse
import subprocess
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
CREDITS = ROOT / "CREDITS.md"
START = "<!-- contributors:start -->"
END = "<!-- contributors:end -->"
IGNORED = {"dependabot[bot]", "github-actions[bot]"}


def contributor_names():
    result = subprocess.run(
        ["git", "log", "--format=%aN"],
        cwd=ROOT,
        check=True,
        capture_output=True,
        text=True,
    )
    names = {name.strip() for name in result.stdout.splitlines() if name.strip()}
    return sorted(names - IGNORED, key=str.casefold)


def render(current):
    before, marker, remainder = current.partition(START)
    if not marker:
        raise ValueError(f"missing {START}")
    _, marker, after = remainder.partition(END)
    if not marker:
        raise ValueError(f"missing {END}")
    generated = "\n".join(f"- {name}" for name in contributor_names())
    return f"{before}{START}\n{generated}\n{END}{after}"


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true")
    args = parser.parse_args()
    current = CREDITS.read_text(encoding="utf-8")
    expected = render(current)
    if args.check:
        if current != expected:
            print("CREDITS.md is stale; run ./tools/update-credits")
            return 1
        return 0
    CREDITS.write_text(expected, encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
