#!/bin/bash
set -u

# Desktop Mode is a Batocera Ports title.  emulatorlauncher already owns the
# synchronous ES -> external application -> ES lifecycle, including display,
# audio, hotkeys, and cleanup.  Plasma must remain its foreground child.
enable_marker=/userdata/system/configs/arch-plasma.enabled
session=/userdata/system/add-ons/desktop/helpers/arch-plasma-session.sh
controller=/userdata/system/add-ons/desktop/helpers/desktop-controller.sh
lock=/tmp/arch-plasma-desktop.lock
state=/tmp/arch-plasma-desktop.active
log=/userdata/system/logs/arch-plasma-desktop.log

mkdir -p "$(dirname "$log")"
exec 9>"$lock"
if ! flock -n 9; then
    printf '%s desktop request ignored: another session owns the lock\n' \
        "$(date -Iseconds)" >>"$log"
    exit 1
fi

log_message() {
    printf '%s %s\n' "$(date -Iseconds)" "$*" >>"$log"
}

launched_by_desktop_port() {
    pid=$PPID
    while [ "$pid" -gt 1 ] 2>/dev/null; do
        command=$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null)
        case "$command" in
            *emulatorlauncher*Desktop\ Mode.sh*) return 0 ;;
        esac
        pid=$(awk '{print $4}' "/proc/$pid/stat" 2>/dev/null)
        case "$pid" in ''|*[!0-9]*) return 1 ;; esac
    done
    return 1
}

cleaned=false
cleanup() {
    status=$?
    [ "$cleaned" = false ] || exit "$status"
    cleaned=true
    trap - EXIT INT TERM HUP
    "$session" stop >/dev/null 2>&1 || true
    "$controller" stop >/dev/null 2>&1 || true
    rm -f "$state"
    log_message "desktop transaction ended with status $status"
    exit "$status"
}
trap cleanup EXIT INT TERM HUP

if [ ! -f "$enable_marker" ]; then
    log_message "desktop request refused: Plasma is not validated/enabled"
    exit 1
fi
if [ ! -x "$session" ]; then
    log_message "desktop request refused: missing $session"
    exit 1
fi
if ! launched_by_desktop_port; then
    log_message "desktop request refused: not launched by Batocera's Desktop Mode port"
    exit 1
fi

printf '%s\n' "$$" >"$state"
log_message "starting foreground Plasma session under emulatorlauncher"
"$session" start >>"$log" 2>&1
session_status=$?
log_message "Plasma session returned with status $session_status"
exit "$session_status"
