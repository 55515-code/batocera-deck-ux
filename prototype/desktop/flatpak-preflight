#!/usr/bin/env python3
"""Read-only Flatpak capability qualification for live and candidate images."""

from __future__ import annotations

import argparse
import gzip
import json
import os
import pathlib
import platform
import shutil
import subprocess
import sys
from dataclasses import asdict, dataclass
from typing import Sequence


EXIT_CODES = {"supported": 0, "unsupported": 1, "inconclusive": 2}
PORTAL_PATHS = ("/usr/lib", "/usr/libexec", "/usr/lib/xdg-desktop-portal")


@dataclass(frozen=True)
class Probe:
    name: str
    status: str
    summary: str
    action: str = ""


def run_command(argv: Sequence[str], timeout: float = 10.0) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            argv,
            check=False,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired as error:
        stdout = error.stdout.decode() if isinstance(error.stdout, bytes) else (error.stdout or "")
        stderr = error.stderr.decode() if isinstance(error.stderr, bytes) else (error.stderr or "")
        return subprocess.CompletedProcess(argv, 124, stdout, stderr or "probe timed out")


def short_error(result: subprocess.CompletedProcess[str]) -> str:
    detail = (result.stderr or result.stdout or "no diagnostic output").strip().splitlines()
    return detail[-1][:300]


def executable(name: str, fallback_paths: Sequence[str] = PORTAL_PATHS) -> str | None:
    found = shutil.which(name)
    if found:
        return found
    for directory in fallback_paths:
        candidate = pathlib.Path(directory, name)
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def read_kernel_config(path: pathlib.Path) -> str:
    if path.suffix == ".gz":
        with gzip.open(path, "rt", errors="replace") as source:
            return source.read()
    return path.read_text(errors="replace")


def kernel_config_candidates(explicit: str | None) -> list[pathlib.Path]:
    if explicit:
        return [pathlib.Path(explicit)]
    release = platform.release()
    return [pathlib.Path("/proc/config.gz"), pathlib.Path(f"/boot/config-{release}")]


def probe_kernel_config(explicit: str | None) -> Probe:
    candidates = kernel_config_candidates(explicit)
    existing = next((path for path in candidates if path.is_file()), None)
    if existing is None:
        checked = ", ".join(str(path) for path in candidates)
        return Probe(
            "kernel_config",
            "inconclusive",
            f"Kernel configuration evidence was unavailable ({checked}).",
            "Publish the candidate kernel config or enable /proc/config.gz, then verify CONFIG_USER_NS=y.",
        )
    try:
        config = read_kernel_config(existing)
    except (OSError, EOFError) as error:
        return Probe(
            "kernel_config",
            "inconclusive",
            f"Could not read {existing}: {error}",
            "Make the exact candidate kernel configuration available to qualification tooling.",
        )
    if "CONFIG_USER_NS=y" in config.splitlines():
        return Probe("kernel_config", "supported", f"{existing} declares CONFIG_USER_NS=y.")
    if "CONFIG_USER_NS=n" in config.splitlines() or "# CONFIG_USER_NS is not set" in config.splitlines():
        return Probe(
            "kernel_config",
            "unsupported",
            f"{existing} explicitly disables CONFIG_USER_NS.",
            "Rebuild the candidate kernel with CONFIG_USER_NS=y before shipping Flatpak.",
        )
    return Probe(
        "kernel_config",
        "inconclusive",
        f"{existing} contains no CONFIG_USER_NS setting.",
        "Verify the complete config for the running candidate kernel.",
    )


def probe_namespace_limit(path: str) -> Probe:
    source = pathlib.Path(path)
    try:
        value = int(source.read_text().strip())
    except (OSError, ValueError) as error:
        return Probe(
            "user_namespace_limit",
            "inconclusive",
            f"Could not read a numeric value from {source}: {error}",
            "Expose user.max_user_namespaces in the candidate runtime and rerun qualification.",
        )
    if value <= 0:
        return Probe(
            "user_namespace_limit",
            "unsupported",
            f"{source} is {value}; unprivileged applications cannot allocate a user namespace.",
            "Correct the image's namespace policy and rebuild it; this tool will not change runtime policy.",
        )
    return Probe("user_namespace_limit", "supported", f"{source} allows {value} user namespaces.")


def probe_unshare() -> Probe:
    command = executable("unshare")
    if command is None:
        return Probe(
            "user_namespace_runtime",
            "inconclusive",
            "The unshare executable is unavailable, so runtime namespace creation was not tested.",
            "Include util-linux unshare in candidate validation images.",
        )
    result = run_command([command, "--user", "--map-root-user", "--", "/bin/true"])
    if result.returncode == 0:
        return Probe("user_namespace_runtime", "supported", "A disposable unprivileged user namespace succeeded.")
    return Probe(
        "user_namespace_runtime",
        "unsupported",
        f"Disposable user namespace creation failed: {short_error(result)}",
        "Inspect the candidate kernel and LSM namespace policy; do not expose Flatpak until this succeeds.",
    )


def probe_bwrap() -> Probe:
    command = executable("bwrap")
    if command is None:
        return Probe(
            "bubblewrap",
            "unsupported",
            "The bwrap executable is unavailable.",
            "Install Bubblewrap as a normal image package and rerun qualification.",
        )
    result = run_command(
        [
            command,
            "--die-with-parent",
            "--unshare-user",
            "--uid",
            "0",
            "--gid",
            "0",
            "--ro-bind",
            "/",
            "/",
            "--proc",
            "/proc",
            "--dev",
            "/dev",
            "/bin/true",
        ]
    )
    if result.returncode == 0:
        return Probe("bubblewrap", "supported", "A disposable Bubblewrap sandbox succeeded.")
    return Probe(
        "bubblewrap",
        "unsupported",
        f"Bubblewrap sandbox creation failed: {short_error(result)}",
        "Inspect the kernel, LSM, and container boundary used by the image; do not weaken host security controls.",
    )


def probe_portals(portal_dirs: Sequence[str]) -> Probe:
    frontend = executable("xdg-desktop-portal", portal_dirs)
    backends = [
        name
        for name in (
            "xdg-desktop-portal-kde",
            "xdg-desktop-portal-cosmic",
            "xdg-desktop-portal-gtk",
            "xdg-desktop-portal-gnome",
            "xdg-desktop-portal-lxqt",
            "xdg-desktop-portal-wlr",
        )
        if executable(name, portal_dirs)
    ]
    missing = []
    if frontend is None:
        missing.append("xdg-desktop-portal")
    if not backends:
        missing.append("a desktop portal backend")
    if missing:
        return Probe(
            "desktop_portals",
            "unsupported",
            f"Missing required executable(s): {', '.join(missing)}.",
            "Install xdg-desktop-portal and the portal backend matching the desktop image.",
        )
    return Probe(
        "desktop_portals",
        "supported",
        f"Portal frontend and backend are executable ({', '.join(backends)}).",
    )


def probe_flatpak_cli() -> Probe:
    if executable("flatpak") is None:
        return Probe(
            "flatpak_cli",
            "unsupported",
            "The flatpak executable is unavailable.",
            "Install Flatpak as an image package before advertising application support.",
        )
    return Probe("flatpak_cli", "supported", "The flatpak executable is available.")


def probe_app_launch(app_id: str, wait_seconds: float) -> Probe:
    command = executable("flatpak")
    if command is None:
        return Probe("app_launch", "unsupported", "Flatpak is unavailable; the requested app was not launched.")
    info = run_command([command, "info", app_id])
    if info.returncode != 0:
        return Probe(
            "app_launch",
            "unsupported",
            f"Requested app {app_id!r} is not installed or readable: {short_error(info)}",
            "Install the selected test application from an approved remote, then rerun this explicit probe.",
        )

    process = subprocess.Popen(
        [command, "run", app_id],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    try:
        stdout, stderr = process.communicate(timeout=wait_seconds)
    except subprocess.TimeoutExpired:
        process.terminate()
        try:
            process.communicate(timeout=3)
        except subprocess.TimeoutExpired:
            process.kill()
            process.communicate()
        return Probe(
            "app_launch",
            "supported",
            f"{app_id} remained running for {wait_seconds:g} seconds and was stopped by the probe.",
        )
    if process.returncode == 0:
        return Probe("app_launch", "supported", f"{app_id} launched and exited successfully.")
    detail = (stderr or stdout or "no diagnostic output").strip().splitlines()[-1][:300]
    return Probe(
        "app_launch",
        "unsupported",
        f"{app_id} exited with status {process.returncode}: {detail}",
        "Review the app, portal, and Bubblewrap diagnostics before enabling it in Discovery.",
    )


def overall_status(probes: Sequence[Probe]) -> str:
    if any(probe.status == "unsupported" for probe in probes):
        return "unsupported"
    if any(probe.status == "inconclusive" for probe in probes):
        return "inconclusive"
    return "supported"


def print_human(status: str, probes: Sequence[Probe]) -> None:
    print(f"Flatpak qualification: {status.upper()}")
    for probe in probes:
        print(f"[{probe.status.upper():12}] {probe.name}: {probe.summary}")
        if probe.action:
            print(f"  Action: {probe.action}")


def parse_args(argv: Sequence[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run non-mutating Flatpak capability checks for candidate and live systems."
    )
    parser.add_argument("--format", choices=("human", "json"), default="human")
    parser.add_argument("--kernel-config", help="Use this kernel config instead of runtime defaults.")
    parser.add_argument(
        "--userns-sysctl",
        default="/proc/sys/user/max_user_namespaces",
        help="Path containing user.max_user_namespaces (primarily useful for offline images/tests).",
    )
    parser.add_argument(
        "--launch-app",
        metavar="APP_ID",
        help="Explicitly launch this installed Flatpak as the final probe; omitted by default.",
    )
    parser.add_argument(
        "--portal-dir",
        action="append",
        dest="portal_dirs",
        help="Portal executable directory to inspect; repeat to override the runtime defaults.",
    )
    parser.add_argument(
        "--launch-wait",
        type=float,
        default=5.0,
        help="Seconds an explicitly launched app must remain alive (default: 5).",
    )
    args = parser.parse_args(argv)
    if args.launch_wait <= 0:
        parser.error("--launch-wait must be greater than zero")
    if args.portal_dirs is None:
        args.portal_dirs = list(PORTAL_PATHS)
    return args


def main(argv: Sequence[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    probes = [
        probe_kernel_config(args.kernel_config),
        probe_namespace_limit(args.userns_sysctl),
        probe_unshare(),
        probe_bwrap(),
        probe_portals(args.portal_dirs),
        probe_flatpak_cli(),
    ]
    if args.launch_app:
        probes.append(probe_app_launch(args.launch_app, args.launch_wait))

    status = overall_status(probes)
    if args.format == "json":
        print(json.dumps({"status": status, "exit_code": EXIT_CODES[status], "probes": [asdict(p) for p in probes]}))
    else:
        print_human(status, probes)
    return EXIT_CODES[status]


if __name__ == "__main__":
    raise SystemExit(main())
