#!/bin/bash
set -u

set_power_save() {
    mode=$1
    found=false
    for iface in /sys/class/net/wlan*; do
        [ -e "$iface" ] || continue
        found=true
        name=$(basename "$iface")
        iw dev "$name" set power_save "$mode" 2>/dev/null || true
        if [ "$mode" = off ] && [ -w "$iface/power/control" ]; then
            printf 'on\n' >"$iface/power/control"
        fi
    done
    [ "$found" = true ]
}

case "${1:-}" in
    start) set_power_save off ;;
    stop) set_power_save on || true ;;
    status)
        for iface in /sys/class/net/wlan*; do
            [ -e "$iface" ] || continue
            iw dev "$(basename "$iface")" get power_save
        done
        ;;
    *) printf 'Usage: %s {start|stop|status}\n' "$0" >&2; exit 2 ;;
esac
