#!/bin/bash
set -u

target=/userdata/steam-sd

source_mount() {
    device=$(findmnt -rn -o SOURCE --target /userdata/roms 2>/dev/null | sed 's/\[.*//')
    [ -n "$device" ] || return 1
    findmnt -rn -S "$device" -o TARGET 2>/dev/null | \
        sed -n '\#^/var/batocera_subdir_#p' | head -n 1
}

case "${1:-}" in
    start)
        source=$(source_mount)
        [ -n "$source" ] && [ -d "$source/steamapps" ] || {
            printf 'Steam SD source is unavailable\n' >&2
            exit 1
        }
        mkdir -p "$target"
        if ! findmnt -rn -o TARGET --target "$target" | grep -Fxq "$target"; then
            mount --bind "$source" "$target"
        fi
        ;;
    stop)
        if findmnt -rn -o TARGET --target "$target" | grep -Fxq "$target"; then
            umount "$target" 2>/dev/null || umount -l "$target" 2>/dev/null || true
        fi
        ;;
    status)
        findmnt -rn -o TARGET,SOURCE --target "$target"
        test -d "$target/steamapps"
        ;;
    *) printf 'Usage: %s {start|stop|status}\n' "$0" >&2; exit 2 ;;
esac
