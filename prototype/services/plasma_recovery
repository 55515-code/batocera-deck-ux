#!/bin/bash
set -u

state=/tmp/arch-plasma-desktop.active
session=/userdata/system/add-ons/desktop/helpers/arch-plasma-session.sh
controller=/userdata/system/add-ons/desktop/helpers/desktop-controller.sh
log=/userdata/system/logs/arch-plasma-recovery.log
pidfile=/tmp/arch-plasma-recovery.pid

recover_if_stale() {
    [ -s "$state" ] || return 0
    pid=$(cat "$state" 2>/dev/null)
    case "$pid" in ''|*[!0-9]*) pid=0 ;; esac
    if [ "$pid" -gt 1 ] && [ -d "/proc/$pid" ]; then
        command=$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null)
        case "$command" in */usr/bin/desktop*|/usr/bin/desktop*) return 0 ;; esac
    fi

    printf '%s recovering stale Desktop Mode transaction\n' "$(date -Iseconds)" >>"$log"
    "$session" stop >>"$log" 2>&1 || true
    "$controller" stop >>"$log" 2>&1 || true
    batocera-mouse hide >/dev/null 2>&1 || true
    rm -f "$state"
}

release_finished_es_wrapper() {
    [ ! -e "$state" ] || return 0
    for process in /proc/[0-9]*; do
        [ "$(cat "$process/comm" 2>/dev/null)" = sh ] || continue
        command=$(tr '\0' ' ' <"$process/cmdline" 2>/dev/null)
        case "$command" in
            *emulatorlauncher*Desktop\\\ Mode.sh*)
                kill -TERM "${process##*/}" 2>/dev/null || true
                ;;
        esac
    done
}

case "${1:-}" in
    start)
        if [ -s "$pidfile" ] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
            exit 0
        fi
        nohup "$0" run >>"$log" 2>&1 </dev/null &
        printf '%s\n' "$!" >"$pidfile"
        ;;
    run)
        trap 'exit 0' INT TERM
        trap 'rm -f "$pidfile"' EXIT
        while true; do
            recover_if_stale
            release_finished_es_wrapper
            sleep 1
        done
        ;;
    stop)
        if [ -s "$pidfile" ]; then
            pid=$(cat "$pidfile")
            kill "$pid" 2>/dev/null || true
            for _ in $(seq 1 20); do
                kill -0 "$pid" 2>/dev/null || break
                sleep 0.1
            done
        fi
        rm -f "$pidfile"
        recover_if_stale
        ;;
    status)
        recover_if_stale
        [ -s "$pidfile" ] && kill -0 "$(cat "$pidfile")" 2>/dev/null
        ;;
    *) printf 'Usage: %s {start|stop|status}\n' "$0" >&2; exit 2 ;;
esac
