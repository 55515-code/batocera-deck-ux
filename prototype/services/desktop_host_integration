#!/bin/sh
set -eu

source_root=/userdata/system/add-ons/desktop/config
pulse_source="$source_root/90-desktop-pulse.conf"
pulse_target=/usr/share/pipewire/pipewire-pulse.conf.d/90-desktop-pulse.conf
connman_source="$source_root/desktop-connman.conf"
connman_target=/etc/dbus-1/system.d/desktop-connman.conf

install_changed() {
    source_file=$1
    target_file=$2
    mode=$3
    [ -f "$source_file" ] || return 1
    if [ -f "$target_file" ] && cmp -s "$source_file" "$target_file"; then
        return 1
    fi
    install -D -m "$mode" "$source_file" "$target_file"
    return 0
}

grant_audio_access() {
    audio_runtime=/run/arch-plasma-audio
    install -d -m 0750 -o root -g 1000 "$audio_runtime"
    retries=0
    while [ "$retries" -lt 50 ] && [ ! -S "$audio_runtime/native" ]; do
        retries=$((retries + 1))
        sleep 0.1
    done
    [ -S "$audio_runtime/native" ] || return 1
    chmod 0660 "$audio_runtime/native"
    setfacl -m u:1000:rw "$audio_runtime/native"
    for socket in /run/pipewire-0 /run/pipewire-0-manager; do
        [ ! -S "$socket" ] || setfacl -m u:1000:rw "$socket"
    done
}

case "${1:-start}" in
    start)
        audio_changed=false
        install -d -m 0750 -o root -g 1000 /run/arch-plasma-audio
        if install_changed "$pulse_source" "$pulse_target" 0644; then
            audio_changed=true
        fi
        if install_changed "$connman_source" "$connman_target" 0644; then
            dbus-send --system --type=method_call \
                --dest=org.freedesktop.DBus / org.freedesktop.DBus.ReloadConfig \
                >/dev/null 2>&1 || true
        fi
        if [ "$audio_changed" = true ]; then
            /etc/init.d/S06audio restart >/dev/null
        fi
        grant_audio_access
        ;;
    stop)
        ;;
    status)
        [ -f "$pulse_target" ] && [ -f "$connman_target" ] && \
            [ -S /run/arch-plasma-audio/native ]
        ;;
    *)
        printf 'Usage: %s {start|stop|status}\n' "$0" >&2
        exit 2
        ;;
esac
