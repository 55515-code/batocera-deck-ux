{
  "schema_version": 1,
  "status": "proposed",
  "purpose": "private-user-data-backup-and-deliberate-sharing",
  "trust": {
    "mutual_device_approval": true,
    "transitive_trust": false,
    "introducer_default": false,
    "single_use_invites": true,
    "invite_expiry_minutes": 15,
    "rights_confirmation_required": true,
    "revocation_erases_recipient_copies": false
  },
  "discovery": {
    "global_catalog": false,
    "public_search": false,
    "stranger_matching": false,
    "global_discovery_default": false,
    "public_relays_default": false,
    "nat_traversal_default": false
  },
  "backends": {
    "trusted_sync": "syncthing",
    "storage_only_backup": "restic",
    "syncthing_untrusted_mode": "experimental",
    "i2p_sam_transport": "experimental"
  },
  "access_modes": [
    "backup-replica",
    "personal-device",
    "shared-reader"
  ],
  "isolation": {
    "separate_from_public_update_service": true,
    "explicit_source_roots_only": true,
    "deny_roots": [
      "/userdata/system/private-bundles",
      "/userdata/system/ssh",
      "/userdata/system/.ssh",
      "/userdata/system/keys",
      "/userdata/bios"
    ]
  },
  "privacy": {
    "claim_anonymity": false,
    "usage_reporting_default": false,
    "clearnet_fallback_from_i2p": false
  }
}
