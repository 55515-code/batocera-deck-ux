{
  "schema_version": 1,
  "application": "batocera-controlcenter",
  "mode": "device-settings",
  "broker": {
    "api_version": 1,
    "allow_arbitrary_commands": false,
    "allow_arbitrary_paths": false,
    "run_ui_as_root": false,
    "require_typed_operations": true
  },
  "input": {
    "controller": true,
    "touch": true,
    "keyboard_mouse": true,
    "external_controller_reconnect": true
  },
  "surfaces": [
    {
      "id": "home",
      "label": "Home",
      "provider": "system.summary",
      "operation": "read",
      "privileged": false,
      "disruptive": false,
      "restart": "none"
    },
    {
      "id": "network",
      "label": "Network",
      "provider": "batocera.network",
      "operation": "manage",
      "privileged": true,
      "disruptive": false,
      "restart": "none"
    },
    {
      "id": "controllers",
      "label": "Bluetooth and Controllers",
      "provider": "batocera.controllers",
      "operation": "manage",
      "privileged": true,
      "disruptive": false,
      "restart": "none"
    },
    {
      "id": "display-audio",
      "label": "Display and Audio",
      "provider": "batocera.av",
      "operation": "configure",
      "privileged": true,
      "disruptive": true,
      "restart": "session"
    },
    {
      "id": "gaming",
      "label": "Gaming and Emulation",
      "provider": "batocera.configgen",
      "operation": "configure-safe-presets",
      "privileged": false,
      "disruptive": false,
      "restart": "game"
    },
    {
      "id": "storage",
      "label": "Storage",
      "provider": "deck.storage",
      "operation": "manage",
      "privileged": true,
      "disruptive": true,
      "restart": "none"
    },
    {
      "id": "desktop-apps",
      "label": "Desktop and Apps",
      "provider": "deck.desktop",
      "operation": "manage",
      "privileged": false,
      "disruptive": false,
      "restart": "session"
    },
    {
      "id": "updates",
      "label": "Updates",
      "provider": "deck.updates",
      "operation": "manage-signed-channels",
      "privileged": true,
      "disruptive": true,
      "restart": "reboot"
    },
    {
      "id": "backup-restore",
      "label": "Backup and Restore",
      "provider": "deck.recovery",
      "operation": "manage",
      "privileged": true,
      "disruptive": true,
      "restart": "reboot"
    },
    {
      "id": "trusted-vaults",
      "label": "Trusted Vaults",
      "provider": "deck.vaults",
      "operation": "manage",
      "privileged": false,
      "disruptive": false,
      "restart": "none"
    },
    {
      "id": "privacy-security",
      "label": "Privacy and Security",
      "provider": "deck.security",
      "operation": "configure",
      "privileged": true,
      "disruptive": false,
      "restart": "none"
    },
    {
      "id": "accessibility",
      "label": "Accessibility",
      "provider": "deck.accessibility",
      "operation": "configure",
      "privileged": false,
      "disruptive": false,
      "restart": "session"
    },
    {
      "id": "diagnostics",
      "label": "About and Diagnostics",
      "provider": "system.diagnostics",
      "operation": "read-redacted",
      "privileged": false,
      "disruptive": false,
      "restart": "none"
    },
    {
      "id": "developer",
      "label": "Developer Mode",
      "provider": "deck.developer",
      "operation": "configure",
      "privileged": true,
      "disruptive": true,
      "restart": "session",
      "hidden_by_default": true
    }
  ]
}
