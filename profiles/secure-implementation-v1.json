{
  "schema_version": 1,
  "id": "luigios-secure-implementation-v1",
  "scope": "luigios-authored-code",
  "security_objectives": {
    "memory_safe_by_default": true,
    "defense_in_depth": true,
    "secure_core_boundaries": true,
    "fail_closed_on_untrusted_input": true,
    "preserve_user_data_during_faults": true,
    "security_is_verified_before_beta": true
  },
  "integration_policy": {
    "prefer_mature_maintained_upstream": true,
    "rewrite_upstream_by_default": false,
    "pin_source_and_dependencies": true,
    "isolate_imported_components": true,
    "preserve_security_update_path": true
  },
  "language_policy": {
    "new_privileged_network_parser_and_daemon_code": "rust",
    "rust_unsafe_forbidden_by_default": true,
    "unsafe_requires_documented_invariant_and_review": true,
    "python_allowed_for_unprivileged_tools": true,
    "shell_limited_to_small_orchestration": true,
    "new_c_or_cpp_requires_abi_hardware_or_upstream_justification": true
  },
  "native_hardening": {
    "pie": true,
    "aslr": true,
    "nx_stack": true,
    "stack_protector_strong": true,
    "full_relro": true,
    "immediate_binding": true,
    "fortify_source_strongest_supported": true,
    "warnings_are_errors": true
  },
  "memory_and_input": {
    "checked_integer_conversions": true,
    "bounded_input_and_allocation": true,
    "archive_path_traversal_rejected": true,
    "decompression_limits_required": true,
    "secret_zeroization_types": true,
    "secrets_excluded_from_logs_and_argv": true,
    "core_dumps_disabled_for_secret_services": true,
    "low_memory_fault_behavior_tested": true
  },
  "runtime": {
    "unprivileged_by_default": true,
    "typed_privilege_broker": true,
    "arbitrary_privileged_commands": false,
    "no_new_privs": true,
    "capability_allowlist": true,
    "read_only_code_and_configuration": true,
    "bounded_writable_state": true,
    "resource_limits": true,
    "kernel_sandbox_when_supported": true,
    "custom_cryptography": false
  },
  "core_security": {
    "privileged_core_services_are_minimal": true,
    "core_services_have_explicit_trust_boundaries": true,
    "emulator_and_desktop_apps_run_unprivileged": true,
    "untrusted_content_is_parsed_in_bounded_processes": true,
    "crash_recovery_is_non_destructive": true,
    "update_and_rollback_metadata_is_authenticated": true,
    "security_controls_are_documented_when_unavailable": true
  },
  "verification": {
    "locked_dependency_audit": true,
    "static_analysis": true,
    "address_sanitizer_for_native_code": true,
    "undefined_behavior_sanitizer_for_native_code": true,
    "fuzz_untrusted_parsers_and_protocols": true,
    "miri_for_rust_unsafe_when_supported": true,
    "negative_and_malformed_input_tests": true,
    "sbom_provenance_and_checksums": true,
    "stable_security_review": true
  }
}
