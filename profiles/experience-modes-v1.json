{
  "schema_version": 1,
  "default_mode": "gamer",
  "product_identity_policy": "product-identity-v1.json",
  "settings_provider": "deck.developer",
  "modes": {
    "gamer": {
      "audience": "end-user",
      "controller_first": true,
      "full_device_configuration_gui": true,
      "show_terminal": false,
      "show_root_filesystem": false,
      "show_package_manager_internals": false,
      "show_raw_service_logs": false,
      "show_unsupported_toggles": false,
      "translate_system_errors": true,
      "prefer_task_language": true
    },
    "developer": {
      "audience": "developer",
      "inherits": "gamer",
      "controller_first": true,
      "full_device_configuration_gui": true,
      "show_terminal": true,
      "show_root_filesystem": true,
      "show_package_manager_internals": true,
      "show_raw_service_logs": true,
      "show_unsupported_toggles": true,
      "translate_system_errors": true,
      "prefer_task_language": true
    }
  },
  "activation": {
    "entry_surface": "developer",
    "requires_explicit_confirmation": true,
    "requires_owner_authentication_when_configured": true,
    "requires_session_restart": true,
    "may_be_enabled_silently": false,
    "show_risk_summary": true,
    "recovery_can_disable": true
  },
  "security_invariants": {
    "ui_runs_as_root": false,
    "allow_arbitrary_privileged_commands": false,
    "signed_update_verification_always_enabled": true,
    "base_image_immutable": true,
    "typed_privilege_broker_required": true,
    "developer_mode_is_not_a_security_boundary": true
  },
  "developer_connectivity": {
    "protect_active_ssh_sessions": true,
    "monitor_default_route": true,
    "remember_last_healthy_wifi_service": true,
    "reconnect_through_existing_connman": true,
    "restart_network_stack": false,
    "replace_network_policy": false,
    "grace_seconds_after_disconnect": 900,
    "maximum_retry_backoff_seconds": 120,
    "reenable_wifi_only_if_powered_at_session_start": true,
    "active_outside_developer_mode": false
  },
  "presentation": {
    "single_settings_application": true,
    "single_app_library": true,
    "hide_duplicate_upstream_control_panels": true,
    "hide_distribution_and_package_jargon_in_gamer_mode": true,
    "keep_upstream_licenses_and_credits_accessible": true,
    "terminal_is_never_required_for_supported_workflows": true,
    "developer_tools_remain_gui_discoverable": true
  }
}
