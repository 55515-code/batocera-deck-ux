{
  "schema_version": 1,
  "status": "proposed",
  "system_definition_source": "batocera-es-system/es_systems.yml",
  "library": {
    "source_template": "/userdata/roms/{system}",
    "destination_template": "/userdata/roms/{system}",
    "access_default": "shared-reader",
    "publisher_mode": "send-only",
    "recipient_staging": "/userdata/system/trusted-vaults/staging/{vault_id}",
    "atomic_import": true,
    "refresh_emulationstation_after_commit": true
  },
  "selection": {
    "modes": ["system", "collection", "selected-title"],
    "derive_extensions_from_system_definitions": true,
    "include_metadata_default": true,
    "include_artwork_default": true,
    "include_saves_default": false,
    "include_raw_configs": false
  },
  "import": {
    "quarantine_before_library": true,
    "verify_manifest_hashes": true,
    "reject_unknown_systems": true,
    "reject_unknown_extensions": true,
    "conflict_default": "keep-both",
    "free_space_reservation": true,
    "rollback_journal": true,
    "auto_execute_received_files": false
  },
  "restricted": {
    "systems_default_disabled": ["ports", "windows", "steam", "flatpak"],
    "deny_paths": [
      "/userdata/bios",
      "/userdata/system",
      "/userdata/saves"
    ],
    "deny_names": ["prod.keys", "title.keys", "keys.txt"],
    "raw_emulator_config_transfer": false,
    "account_and_credential_transfer": false,
    "firmware_and_bios_transfer": false
  },
  "presets": {
    "format": "versioned-declarative-allowlist",
    "allow_commands": false,
    "allow_absolute_paths": false,
    "allow_credentials": false,
    "require_preview": true
  }
}
