{
  "schema": 1,
  "name": "steamdeck-private-system",
  "description": "User-owned firmware, emulator configuration, and save state. Never distribute this bundle.",
  "components": [
    {"category": "firmware", "path": "/userdata/bios"},
    {"category": "firmware", "path": "/userdata/system/configs/rpcs3/dev_flash"},
    {"category": "firmware", "path": "/userdata/saves/psvita/vs0"},
    {"category": "firmware", "path": "/userdata/saves/psvita/sa0"},
    {"category": "config", "path": "/userdata/system/configs/Ryujinx"},
    {"category": "config", "path": "/userdata/system/configs/cemu"},
    {"category": "config", "path": "/userdata/system/configs/dolphin-emu"},
    {"category": "config", "path": "/userdata/system/configs/emulationstation"},
    {"category": "config", "path": "/userdata/system/configs/mupen64"},
    {"category": "config", "path": "/userdata/system/configs/retroarch"},
    {"category": "config", "path": "/userdata/system/configs/rpcs3", "exclude": ["dev_flash/**", "cache/**", "shaderlog/**"]},
    {"category": "config", "path": "/userdata/system/configs/vita3k"},
    {"category": "config", "path": "/userdata/system/configs/xemu"},
    {"category": "config", "path": "/userdata/system/configs/yuzu"},
    {"category": "config", "path": "/userdata/system/configs/hotkeys.keys"},
    {"category": "save", "path": "/userdata/saves", "exclude": ["flatpak/**", "ps3/rpcs3/dev_hdd0/game/**", "psvita/ux0/app/**"]}
  ]
}
