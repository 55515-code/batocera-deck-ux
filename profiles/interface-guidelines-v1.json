{
  "schema_version": 1,
  "id": "luigios-interface-guidelines-v1",
  "design_origin": {
    "original_luigios_system_required": true,
    "third_party_products_may_be_studied_for_general_usability": true,
    "copy_proprietary_trade_dress": false,
    "copy_proprietary_assets_or_sounds": false,
    "copy_proprietary_screen_geometry": false,
    "nominative_compatibility_labels_allowed": true
  },
  "navigation": {
    "controller_complete": true,
    "single_visible_focus": true,
    "predictable_back_path": true,
    "semantic_actions_resolve_through_active_controller_profile": true,
    "pointer_only_actions_allowed": false,
    "focus_traps_allowed": false
  },
  "layout": {
    "handheld_reference": "1280x800",
    "television_reference": "1920x1080",
    "minimum_touch_target_logical_px": 44,
    "viewport_scaled_type": false,
    "stable_control_dimensions": true,
    "oled_black_dominant_dark_surface": true
  },
  "performance": {
    "input_feedback_budget_ms": 100,
    "navigation_animation_budget_ms": 200,
    "animations_interruptible": true,
    "local_content_precedes_online_enrichment": true
  },
  "vanilla_offline_contract": {
    "deployment_requires_network": false,
    "first_boot_requires_network": false,
    "first_boot_requires_login": false,
    "network_setup_skippable": true,
    "local_library_requires_login": false,
    "local_play_requires_network": false,
    "device_settings_require_network": false,
    "controller_pairing_requires_login": false,
    "backup_restore_reset_require_login": false,
    "recovery_requires_network": false
  },
  "optional_service_contract": {
    "third_party_service_may_require_own_login": true,
    "third_party_service_may_require_network": true,
    "requirement_scoped_to_optional_service": true,
    "service_operator_identified_before_handoff": true,
    "vanilla_shell_blocked_by_service": false,
    "local_device_controls_blocked_by_service": false,
    "visible_sign_out_and_local_data_removal": true
  },
  "release_evidence": {
    "controller_only_handheld": true,
    "controller_only_television": true,
    "offline_first_boot": true,
    "no_account_local_play": true,
    "proprietary_trade_dress_review": true,
    "localization_expansion": true,
    "accessibility": true
  }
}
