{
  "schema_version": 1,
  "current_channel": "experimental",
  "reference_platform": "steam-deck",
  "beta_entry": {
    "all_required": true,
    "gates": [
      "reproducible-image",
      "complete-brand-surfaces",
      "desktop-session",
      "developer-connectivity-protection",
      "controller-and-display-matrix",
      "settings-application",
      "backup-restore",
      "migration",
      "offline-no-account-vanilla",
      "original-interface-review",
      "secure-implementation-review",
      "update-rollback",
      "reference-device-regression"
    ],
    "required_brand_slots": [
      "boot.splash",
      "game-mode.theme",
      "desktop.wallpaper",
      "system.settings-icons",
      "system.recovery"
    ],
    "desktop_acceptance": {
      "runs_unprivileged": true,
      "fullscreen_handheld_and_hdmi": true,
      "built_in_and_external_controller": true,
      "visible_pointer_and_osk": true,
      "audio_and_network_management": true,
      "flatpak_gui_launch": true,
      "clean_return_to_game_mode": true,
      "survives_suspend_and_reconnect": true
    },
    "settings_acceptance": {
      "controller_first": true,
      "no_terminal_required": true,
      "typed_privilege_broker": true,
      "backup_and_migration_visible": true,
      "recovery_action_for_failures": true
    },
    "interface_acceptance": {
      "policy": "interface-guidelines-v1.json",
      "offline_first_boot_and_local_play": true,
      "network_setup_skippable": true,
      "no_account_required_for_local_administration": true,
      "third_party_login_scoped_to_service": true,
      "proprietary_trade_dress_review": true
    },
    "secure_implementation_acceptance": {
      "policy": "secure-implementation-v1.json",
      "memory_safe_default_for_new_sensitive_code": true,
      "native_binary_hardening_verified": true,
      "unsafe_and_native_exceptions_documented": true,
      "dependency_and_static_analysis": true,
      "sanitizer_and_fuzz_evidence_where_applicable": true,
      "least_privilege_runtime_review": true
    }
  },
  "device_qa": {
    "transport": "ssh",
    "read_only_by_default": true,
    "preserve_active_ssh_until_postflight": true,
    "never_restart_network_during_remote_deploy": true,
    "minimum_userdata_free_percent": 15,
    "minimum_userdata_free_kib": 10485760,
    "rom_mount": "/userdata/roms",
    "expected_removable_source_prefix": "/dev/mmcblk",
    "hard_deny_write_roots": [
      "/userdata/roms",
      "/media",
      "/boot"
    ],
    "allowed_experimental_staging_roots": [
      "/userdata/system/add-ons/luigios",
      "/userdata/system/configs/luigios",
      "/userdata/system/backups"
    ]
  },
  "fresh_install": {
    "allowed_only_after_beta_entry": true,
    "backup_rom_payloads": false,
    "inventory_rom_mount_without_modification": true,
    "require_verified_non_rom_backup": true,
    "physically_remove_rom_sd_during_install": true,
    "never_format_or_initialize_existing_rom_sd": true,
    "restore_order": [
      "install-internal-device-with-rom-sd-removed",
      "boot-and-verify-internal-target",
      "reinsert-rom-sd",
      "verify-filesystem-identity-before-use",
      "mount-existing-filesystem-without-format",
      "dry-run-private-system-restore",
      "apply-private-system-restore",
      "index-existing-rom-library",
      "run-reference-device-regression"
    ]
  }
}
