{
  "schema_version": 1,
  "reference_platform": {
    "id": "steam-deck",
    "label": "Steam Deck",
    "role": "core-development-device",
    "core_project_release_gate": true,
    "variants_require_independent_evidence": true,
    "blanket_compatibility_claim": false
  },
  "tiers": {
    "reference": {
      "core_project_maintained": true,
      "release_blocking": true,
      "requires_core_hardware_access": true,
      "support_promise": "documented-release-scope-only"
    },
    "community-tested": {
      "core_project_maintained": false,
      "release_blocking": false,
      "requires_current_test_evidence": true,
      "support_promise": "none"
    },
    "downstream-maintained": {
      "core_project_maintained": false,
      "release_blocking": false,
      "requires_named_maintainer": true,
      "requires_public_support_contact_for_sold_devices": true,
      "support_promise": "provided-by-downstream"
    },
    "experimental": {
      "core_project_maintained": false,
      "release_blocking": false,
      "may_lack_current_test_evidence": true,
      "support_promise": "none"
    },
    "unverified": {
      "core_project_maintained": false,
      "release_blocking": false,
      "compatibility_claim": false,
      "support_promise": "none"
    }
  },
  "evidence": {
    "bound_to_image_digest": true,
    "bound_to_hardware_revision": true,
    "bound_to_firmware_version": true,
    "records_skipped_and_failed_tests": true,
    "expires_when_materially_stale": true,
    "one_variant_implies_family_support": false
  },
  "device_profile_acceptance": {
    "must_be_isolated_from_reference_defaults": true,
    "must_be_capability_driven": true,
    "must_fail_closed_on_wrong_hardware": true,
    "must_include_rollback_or_removal": true,
    "must_include_physical_test_evidence": true,
    "must_not_regress_reference_platform": true,
    "core_project_may_merge_without_support_ownership": true
  },
  "language": {
    "avoid_unqualified_supported_label": true,
    "display_tier_and_evidence_date": true,
    "display_responsible_support_party": true,
    "compatibility_listing_is_not_certification": true
  }
}
