{
  "schema_version": 1,
  "product": {
    "display_name": "LuigiOS",
    "spoken_name": "Luigi O S",
    "tagline": "Games first. Your device. Your choices.",
    "reference_platform": "steam-deck"
  },
  "mission": {
    "primary_audience": "people-who-play-games",
    "primary_task": "find-and-play-a-game",
    "implementation_serves_interface": true,
    "player_controls_device": true,
    "company_controls_device": false
  },
  "default_experience": {
    "mode": "gamer",
    "controller_first": true,
    "works_offline": true,
    "mandatory_luigios_account": false,
    "mandatory_subscription": false,
    "advertising": false,
    "sponsored_ranking": false,
    "forced_storefront": false,
    "telemetry_enabled_by_default": false,
    "terminal_required": false
  },
  "vanilla_distribution": {
    "deployment_requires_network": false,
    "first_boot_network_optional": true,
    "first_boot_requires_login": false,
    "local_library_and_play_require_login": false,
    "local_device_administration_requires_network": false,
    "backup_restore_reset_and_recovery_require_login": false
  },
  "owner_rights": {
    "choose_software_sources": true,
    "remove_optional_software": true,
    "export_user_data": true,
    "backup_restore_and_reset": true,
    "inspect_installed_components": true,
    "enable_developer_mode": true,
    "replace_branding_in_downstreams": true,
    "decline_peer_distribution": true,
    "decline_diagnostics_upload": true
  },
  "trust_boundaries": {
    "third_party_services_remain_identified": true,
    "third_party_accounts_only_when_service_requires": true,
    "proprietary_downstream_services_may_require_own_login": true,
    "third_party_login_requirement_scoped_to_service": true,
    "third_party_service_cannot_gate_vanilla_shell": true,
    "commercial_relationships_never_bypass_qa": true,
    "commercial_relationships_never_bypass_release_trust": true,
    "security_updates_remain_signed": true,
    "developer_mode_does_not_disable_security": true
  },
  "language": {
    "preferred": ["Games", "Library", "Play", "Apps", "Storage", "Updates", "Controllers", "Recovery"],
    "implementation_terms_hidden_in_gamer_mode": ["package", "daemon", "mount", "root", "unit", "chroot"],
    "error_messages_include_recovery_action": true,
    "upstream_names_preserved_for_credits_and_diagnostics": true,
    "never_imply_ownership_of_third_party_software": true
  }
}
