config BR2_PACKAGE_BATOCERA_DECK_BUA
	bool "Batocera Unofficial Add-Ons store integration"
	depends on BR2_x86_64
	default y
	select BR2_PACKAGE_PYTHON3
	select BR2_PACKAGE_PYTHON_PYGAME2
	help
	  Install the GPL-3.0 Batocera Unofficial Add-Ons (BUA) community
	  store and expose it in both Batocera Ports and desktop menus.

	  BUA is an independent upstream project. Add-ons selected in BUA are
	  not part of, signed by, or supported as components of the base OS.
