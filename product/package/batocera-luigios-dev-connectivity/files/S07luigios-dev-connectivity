#!/bin/sh
set -eu

program=/usr/libexec/luigios/dev-connectivity-guard
runtime=/run/luigios-dev-connectivity
pidfile=$runtime/guard.pid

valid_pid() {
    [ -s "$pidfile" ] || return 1
    pid=$(cat "$pidfile" 2>/dev/null || true)
    case "$pid" in *[!0-9]*|'') return 1 ;; esac
    [ -r "/proc/$pid/cmdline" ] || return 1
    tr '\0' ' ' <"/proc/$pid/cmdline" | grep -Fq "$program daemon"
}

case "${1:-}" in
    start)
        valid_pid && exit 0
        install -d -m 0750 "$runtime"
        start-stop-daemon -S -b -m -p "$pidfile" -x "$program" -- daemon
        ;;
    stop)
        valid_pid && start-stop-daemon -K -p "$pidfile" -x "$program" || true
        rm -f "$pidfile"
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    status)
        valid_pid
        ;;
    *)
        printf 'Usage: %s {start|stop|restart|status}\n' "$0" >&2
        exit 2
        ;;
esac
