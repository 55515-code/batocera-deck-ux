#!/bin/sh
set -eu

mode_marker=${LUIGIOS_DEVELOPER_MODE_MARKER:-/userdata/system/configs/luigios/developer-mode.enabled}
runtime=${LUIGIOS_DEV_CONNECTIVITY_RUNTIME:-/run/luigios-dev-connectivity}
poll_seconds=${LUIGIOS_DEV_CONNECTIVITY_POLL_SECONDS:-5}
grace_seconds=${LUIGIOS_DEV_CONNECTIVITY_GRACE_SECONDS:-900}
max_backoff=${LUIGIOS_DEV_CONNECTIVITY_MAX_BACKOFF:-120}

last_ssh=$runtime/last-ssh
last_service=$runtime/last-wifi-service
radio_baseline=$runtime/radio-was-powered
next_attempt=$runtime/next-attempt
backoff_file=$runtime/backoff
status_file=$runtime/status

now() { date +%s; }

active_ssh() {
    if [ "${LUIGIOS_DEV_CONNECTIVITY_ACTIVE_SSH:-}" = 1 ]; then
        return 0
    fi
    for environment in /proc/[0-9]*/environ; do
        [ -r "$environment" ] || continue
        tr '\0' '\n' <"$environment" 2>/dev/null | grep -q '^SSH_CONNECTION=' && return 0
    done
    return 1
}

default_route_healthy() {
    ip route show default 2>/dev/null | grep -q '^default '
}

wifi_powered() {
    connmanctl technologies 2>/dev/null | awk '
        /^  Name = WiFi$/ { wifi=1; next }
        wifi && /^  Powered = True$/ { found=1; exit }
        wifi && /^  Name = / { exit }
        END { exit(found ? 0 : 1) }
    '
}

connected_wifi_service() {
    connmanctl services 2>/dev/null | awk '
        $1 ~ /^\*.*[ARO]/ && $NF ~ /^wifi_[A-Za-z0-9]+_.*_managed_/ { print $NF; exit }
    '
}

valid_service() {
    printf '%s\n' "$1" | grep -Eq '^wifi_[A-Za-z0-9]+_.*_managed_[A-Za-z0-9]+$'
}

write_status() {
    state=$1
    detail=${2:-}
    temporary=$runtime/status.tmp.$$
    printf 'state=%s\ndetail=%s\nupdated=%s\n' "$state" "$detail" "$(now)" >"$temporary"
    chmod 0640 "$temporary"
    mv -f "$temporary" "$status_file"
}

reset_backoff() {
    printf '5\n' >"$backoff_file"
    printf '0\n' >"$next_attempt"
}

record_healthy_session() {
    timestamp=$(now)
    printf '%s\n' "$timestamp" >"$last_ssh"
    service=$(connected_wifi_service || true)
    if [ -n "$service" ] && valid_service "$service"; then
        printf '%s\n' "$service" >"$last_service"
    fi
    if [ ! -e "$radio_baseline" ]; then
        if wifi_powered; then
            printf 'yes\n' >"$radio_baseline"
        else
            printf 'no\n' >"$radio_baseline"
        fi
    fi
    reset_backoff
    write_status protected "active SSH development session"
}

protection_recent() {
    [ -s "$last_ssh" ] || return 1
    timestamp=$(cat "$last_ssh" 2>/dev/null || printf 0)
    case "$timestamp" in *[!0-9]*|'') return 1 ;; esac
    [ $(( $(now) - timestamp )) -le "$grace_seconds" ]
}

attempt_reconnect() {
    timestamp=$(now)
    allowed=$(cat "$next_attempt" 2>/dev/null || printf 0)
    case "$allowed" in *[!0-9]*|'') allowed=0 ;; esac
    [ "$timestamp" -ge "$allowed" ] || return 0

    service=$(cat "$last_service" 2>/dev/null || true)
    if [ -z "$service" ] || ! valid_service "$service"; then
        write_status waiting "no previously healthy Wi-Fi service"
        return 0
    fi

    if ! wifi_powered && [ "$(cat "$radio_baseline" 2>/dev/null || true)" = yes ]; then
        connmanctl enable wifi >/dev/null 2>&1 || true
    fi
    write_status reconnecting "$service"
    connmanctl connect "$service" >/dev/null 2>&1 || true

    backoff=$(cat "$backoff_file" 2>/dev/null || printf 5)
    case "$backoff" in *[!0-9]*|'') backoff=5 ;; esac
    [ "$backoff" -le "$max_backoff" ] || backoff=$max_backoff
    printf '%s\n' $(( timestamp + backoff )) >"$next_attempt"
    doubled=$(( backoff * 2 ))
    [ "$doubled" -le "$max_backoff" ] || doubled=$max_backoff
    printf '%s\n' "$doubled" >"$backoff_file"
    logger -t luigios-dev-connectivity "requested reconnect for protected SSH work using $service"
}

check_once() {
    install -d -m 0750 "$runtime"
    if [ ! -e "$mode_marker" ]; then
        rm -f "$last_ssh" "$last_service" "$radio_baseline" "$next_attempt" "$backoff_file"
        write_status dormant "Developer Mode is disabled"
        return 0
    fi

    if active_ssh && default_route_healthy; then
        record_healthy_session
        return 0
    fi
    if ! protection_recent; then
        write_status idle "no active or recent SSH development session"
        return 0
    fi
    if default_route_healthy; then
        reset_backoff
        write_status grace "SSH protection grace window"
        return 0
    fi
    attempt_reconnect
}

case "${1:-}" in
    once) check_once ;;
    daemon)
        while :; do
            check_once
            sleep "$poll_seconds"
        done
        ;;
    status)
        cat "$status_file" 2>/dev/null || printf 'state=unknown\ndetail=guard has not run\n'
        ;;
    *) printf 'Usage: %s {once|daemon|status}\n' "$0" >&2; exit 2 ;;
esac
