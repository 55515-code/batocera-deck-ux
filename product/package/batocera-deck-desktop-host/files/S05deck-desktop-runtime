#!/bin/sh
set -eu

runtime=/run/batocera-deck-desktop

case "${1:-}" in
    start)
        install -d -m 0750 -o root -g 1000 "$runtime" "$runtime/audio"
        ;;
    stop)
        rm -f "$runtime/command" "$runtime/controller.pid" "$runtime/session.pid"
        ;;
    status)
        [ -d "$runtime" ] && [ "$(stat -c %a "$runtime")" = 750 ]
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        printf 'Usage: %s {start|stop|status|restart}\n' "$0" >&2
        exit 2
        ;;
esac
