#!/bin/bash
set -u

enable_marker=/userdata/system/configs/batocera-deck-desktop.enabled
session=/usr/libexec/batocera-deck-desktop/arch-cosmic-session
lock=/run/batocera-deck-desktop/launch.lock
state=/run/batocera-deck-desktop/desktop.active
log=/userdata/system/logs/batocera-deck-desktop.log

mkdir -p "$(dirname "$log")"
exec 9>"$lock"
if ! flock -n 9; then
    printf '%s desktop request refused: another session owns the lock\n' \
        "$(date -Iseconds)" >>"$log"
    exit 1
fi

log_message() {
    printf '%s %s\n' "$(date -Iseconds)" "$*" >>"$log"
}

launched_by_desktop_port() {
    pid=$PPID
    while [ "$pid" -gt 1 ] 2>/dev/null; do
        command=$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null)
        case "$command" in
            *emulatorlauncher*Desktop\ Mode.sh*) return 0 ;;
        esac
        pid=$(awk '{print $4}' "/proc/$pid/stat" 2>/dev/null)
        case "$pid" in ''|*[!0-9]*) return 1 ;; esac
    done
    return 1
}

cleaned=false
cleanup() {
    status=$?
    [ "$cleaned" = false ] || exit "$status"
    cleaned=true
    trap - EXIT INT TERM HUP
    "$session" stop >/dev/null 2>&1 || true
    rm -f "$state"
    log_message "desktop transaction ended with status $status"
    exit "$status"
}
trap cleanup EXIT INT TERM HUP

[ -f "$enable_marker" ] || {
    log_message "desktop request refused: experimental feature is not enabled"
    exit 1
}
[ -x "$session" ] || exit 1
launched_by_desktop_port || {
    log_message "desktop request refused: launcher is outside emulatorlauncher lifecycle"
    exit 1
}

printf '%s:%s\n' "$$" "$(awk '{print $22}' /proc/$$/stat)" >"$state"
log_message "starting foreground COSMIC session"
"$session" start >>"$log" 2>&1
