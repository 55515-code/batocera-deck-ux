#!/bin/sh
set -eu

runtime=/run/batocera-deck-desktop
audio_socket="$runtime/audio/native"

start_service() {
    /etc/init.d/S05deck-desktop-runtime start
    retries=0
    while [ "$retries" -lt 50 ] && [ ! -S "$audio_socket" ]; do
        retries=$((retries + 1))
        sleep 0.1
    done
    [ -S "$audio_socket" ] || {
        echo "Desktop audio endpoint is unavailable" >&2
        return 1
    }
    chmod 0660 "$audio_socket"
    setfacl -m u:1000:rw "$audio_socket"
}

case "${1:-}" in
    start) start_service ;;
    stop) /usr/libexec/batocera-deck-desktop/arch-cosmic-session stop || true ;;
    status)
        # Status is deliberately observational.
        [ -S "$audio_socket" ] &&
            [ -x /usr/libexec/batocera-deck-desktop/cosmic-gamepad-bridge ]
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    *)
        printf 'Usage: %s {start|stop|status|restart}\n' "$0" >&2
        exit 2
        ;;
esac
