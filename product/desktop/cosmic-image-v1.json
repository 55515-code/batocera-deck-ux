{
  "schema_version": 1,
  "id": "luigios-arch-cosmic-x86_64-v1",
  "architecture": "x86_64",
  "distribution": "Arch Linux",
  "desktop": {
    "name": "COSMIC",
    "version_floor": "1.3.0",
    "session": "/usr/bin/cosmic-session",
    "compositor": "/usr/bin/cosmic-comp",
    "backend": "winit"
  },
  "paths": {
    "rootfs": "/userdata/system/containers/arch-cosmic/rootfs",
    "home": "/userdata/system/containers/arch-cosmic/home/deck",
    "previous_plasma_home": "/userdata/system/containers/arch-plasma/home/deck"
  },
  "required_packages": [
    "bash",
    "bluez",
    "bluez-utils",
    "cosmic-app-library",
    "cosmic-applets",
    "cosmic-bg",
    "cosmic-comp",
    "cosmic-files",
    "cosmic-greeter",
    "cosmic-icon-theme",
    "cosmic-idle",
    "cosmic-initial-setup",
    "cosmic-launcher",
    "cosmic-monitor",
    "cosmic-notifications",
    "cosmic-osd",
    "cosmic-panel",
    "cosmic-player",
    "cosmic-randr",
    "cosmic-screenshot",
    "cosmic-session",
    "cosmic-settings",
    "cosmic-settings-daemon",
    "cosmic-store",
    "cosmic-terminal",
    "cosmic-text-editor",
    "cosmic-wallpapers",
    "cosmic-workspaces",
    "dbus",
    "flatpak",
    "gnome-keyring",
    "gvfs",
    "gvfs-nfs",
    "gvfs-smb",
    "libpulse",
    "mesa",
    "polkit",
    "util-linux",
    "vulkan-radeon",
    "xdg-desktop-portal",
    "xdg-desktop-portal-cosmic",
    "xdg-desktop-portal-gtk"
  ],
  "required_executables": [
    "/usr/bin/cosmic-app-library",
    "/usr/bin/cosmic-comp",
    "/usr/bin/cosmic-files",
    "/usr/bin/cosmic-launcher",
    "/usr/bin/cosmic-monitor",
    "/usr/bin/cosmic-panel",
    "/usr/bin/cosmic-session",
    "/usr/bin/cosmic-settings",
    "/usr/bin/cosmic-store",
    "/usr/bin/cosmic-term",
    "/usr/lib/xdg-desktop-portal",
    "/usr/lib/xdg-desktop-portal-cosmic",
    "/usr/lib/xdg-desktop-portal-gtk"
  ],
  "attestation": {
    "build": "/usr/share/luigios/cosmic-image-build.json",
    "sbom": "/usr/share/luigios/cosmic-image.spdx.json"
  },
  "migration": {
    "copy_if_present": [
      "Desktop",
      "Documents",
      "Downloads",
      "Music",
      "Pictures",
      "Videos",
      ".local/share/flatpak"
    ],
    "never_copy": [
      ".cache",
      ".config/kde.org",
      ".config/kwinoutputconfig.json",
      ".config/plasma-org.kde.plasma.desktop-appletsrc",
      ".local/share/plasma"
    ]
  }
}
